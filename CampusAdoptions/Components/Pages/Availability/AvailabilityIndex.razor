@page "/availability"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using CampusAdoptions.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

@inject BookAvailabilityService Svc
@inject IEmailService EmailService
@inject AppDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Items — Availability Report</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <div>
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2" />
            Book Availability Report
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Dark">
            Affordability and digital availability for approved course materials
        </MudText>
    </div>
    <MudSelect T="string" Value="_selectedSemester" Label="Semester" Style="width:200px;"
               ValueChanged="OnSemesterChanged">
        @foreach (var s in _semesters)
        {
            <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
        }
    </MudSelect>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <!-- Affordability Histogram -->
    @if (_items.Any(b => b.AffordabilityScore.HasValue))
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-2">
                Affordability Distribution — Term Average: @_termAvg
            </MudText>
            <MudGrid>
                @for (var i = 0; i < _chartLabels.Length; i++)
                {
                    var idx = i;
                    var maxVal = _chartData.Length > 0 ? _chartData.Max() : 1;
                    var pct = maxVal > 0 ? (int)(_chartData[idx] / maxVal * 100) : 0;
                    <MudItem xs="2" Class="text-center">
                        <div style="height:150px; display:flex; flex-direction:column; justify-content:flex-end; align-items:center;">
                            <MudText Typo="Typo.caption" Style="font-weight:600;">@((int)_chartData[idx])</MudText>
                            <div style="width:40px; height:@(pct)%; background:#0066cc; border-radius:4px 4px 0 0; min-height:4px;"></div>
                        </div>
                        <MudText Typo="Typo.caption">@_chartLabels[idx]</MudText>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }

    <!-- Items Table -->
    <MudPaper Elevation="2">
        <MudTable Items="_items" Hover="true" Dense="true" Filter="FilterFunc">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-2" />
                    Approved Books — @_selectedSemester
                </MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchString" Placeholder="Search..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" DebounceInterval="300" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<BookAvailabilityItem, object>(x => x.CourseNumber)">Course</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<BookAvailabilityItem, object>(x => x.Title)">Title</MudTableSortLabel></MudTh>
                <MudTh>ISBN</MudTh>
                <MudTh>Required</MudTh>
                <MudTh>Price</MudTh>
                <MudTh>Digital</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<BookAvailabilityItem, object>(x => x.AffordabilityScore ?? 0)">Score</MudTableSortLabel></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <strong>@context.CourseNumber</strong><br />
                    <MudText Typo="Typo.caption" Color="Color.Dark">@context.CourseName</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Title</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Dark">@context.Author</MudText>
                </MudTd>
                <MudTd Style="font-size:0.85rem;">@context.Isbn</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.IsRequired ? Color.Success : Color.Default)">
                        @(context.IsRequired ? "Required" : "Optional")
                    </MudChip>
                </MudTd>
                <MudTd>
                    @{
                        var price = context.PrintRetailPrice ?? context.PrintListPrice ?? context.EbookPrice;
                    }
                    @if (price.HasValue)
                    {
                        <MudText Typo="Typo.body2"
                                 Color="@(context.PriceFlaggedOver60 ? Color.Error : Color.Default)"
                                 Style="font-weight:600;">
                            $@price.Value.ToString("F2")
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Dark">N/A</MudText>
                    }
                </MudTd>
                <MudTd>
                    @if (context.DigitalAvailableOnVitalSource)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="Color.Success" Style="font-weight:600;">VS</MudText>
                    }
                    @if (context.EbookAvailableOnGoogle)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Info" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="Color.Info" Style="font-weight:600;">Google</MudText>
                    }
                    @if (!context.DigitalAvailableOnVitalSource && !context.EbookAvailableOnGoogle)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Dark">None</MudText>
                    }
                </MudTd>
                <MudTd>
                    @if (context.AffordabilityScore.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.AffordabilityScore >= 60 ? Color.Success : context.AffordabilityScore >= 30 ? Color.Warning : Color.Error)">
                            @context.AffordabilityScore
                        </MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudButton Href="@($"/availability/item?isbn={context.Isbn}")"
                               Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                        Details
                    </MudButton>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private string _selectedSemester = "";
    private string _searchString = "";
    private List<string> _semesters = [];
    private List<BookAvailabilityItem> _items = [];
    private int _termAvg;
    private double[] _chartData = [];
    private string[] _chartLabels = [];

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _semesters = await Svc.GetAvailableSemestersAsync();
        _selectedSemester = _semesters.FirstOrDefault() ?? "";
        await LoadReport();
        _loading = false;
    }

    private async Task OnSemesterChanged(string semester)
    {
        _selectedSemester = semester;
        _loading = true;
        StateHasChanged();
        await LoadReport();
        _loading = false;
    }

    private async Task LoadReport()
    {
        if (string.IsNullOrEmpty(_selectedSemester)) return;

        _items = await Svc.GetReportAsync(_selectedSemester);

        _termAvg = _items.Any(b => b.AffordabilityScore.HasValue)
            ? (int)Math.Round(_items.Where(b => b.AffordabilityScore.HasValue).Average(b => b.AffordabilityScore!.Value))
            : 50;

        BuildChart();
    }

    private void BuildChart()
    {
        var bins = new[] { "0-19", "20-39", "40-59", "60-79", "80-100" };
        var counts = new double[5];
        foreach (var item in _items.Where(b => b.AffordabilityScore.HasValue))
        {
            var s = item.AffordabilityScore!.Value;
            var idx = Math.Min(s / 20, 4);
            counts[idx]++;
        }
        _chartLabels = bins;
        _chartData = counts;
    }

    private bool FilterFunc(BookAvailabilityItem item)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        var s = _searchString.ToLower();
        return item.Title.ToLower().Contains(s)
            || item.Author.ToLower().Contains(s)
            || item.Isbn.ToLower().Contains(s)
            || item.CourseNumber.ToLower().Contains(s);
    }
}
