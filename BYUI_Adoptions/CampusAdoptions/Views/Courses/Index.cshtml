@model List<CampusAdoptions.Controllers.CourseGroup>
@using CampusAdoptions.Models
@{
    ViewData["Title"]     = "Courses";
    ViewData["PageTitle"] = "COURSES";

    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentDept   = ViewBag.CurrentDept   as string ?? "";
    var departments   = ViewBag.Departments   as List<string> ?? new();

    // Professor view: scoped to their own courses only
    var isMyCourses = (bool)(ViewBag.IsMyCourses ?? false);
    var listAction  = isMyCourses ? "MyCourses" : "Index";

    int cntTotal    = ViewBag.CountTotal    ?? 0;
    int cntPending  = ViewBag.CountIncomplete ?? 0;
    int cntVerified = ViewBag.CountSubmitted ?? 0;
    int cntApproved = ViewBag.CountApproved  ?? 0;
    int cntRejected = ViewBag.CountRejected  ?? 0;
}

<style>
/* ── Status tab bar ──────────────────────────────────────────── */
.courses-status-bar {
  display: flex;
  background: #1c2236;
  border-bottom: 2px solid #111;
}
.status-tab {
  flex: 1;
  text-align: center;
  padding: 14px 8px 12px;
  color: #9aa;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .08em;
  text-decoration: none;
  border-bottom: 3px solid transparent;
  transition: all .15s;
  cursor: pointer;
}
.status-tab:hover { color: #fff; background: rgba(255,255,255,.06); }
.status-tab.active {
  color: #fff;
  border-bottom-color: #0d6efd;
  background: rgba(13,110,253,.12);
}
.status-tab .tab-count {
  display: block;
  font-size: 22px;
  font-weight: 800;
  color: inherit;
  margin-bottom: 2px;
  line-height: 1.1;
}

/* ── Page body split ─────────────────────────────────────────── */
.courses-page-body {
  display: flex;
  min-height: calc(100vh - 200px);
  background: #f4f4f4;
}

/* ── Left sidebar ────────────────────────────────────────────── */
.courses-sidebar {
  width: 240px;
  flex-shrink: 0;
  background: #fff;
  border-right: 1px solid #ddd;
  display: flex;
  flex-direction: column;
}
.sidebar-filter-tabs {
  display: flex;
  border-bottom: 2px solid #ddd;
}
.sf-tab {
  flex: 1;
  text-align: center;
  padding: 10px 4px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .06em;
  color: #667;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  text-decoration: none;
}
.sf-tab.active { color: #003B71; border-bottom-color: #003B71; }
.sidebar-search-box {
  padding: 12px;
  border-bottom: 1px solid #eee;
}
.sidebar-search-box input {
  border-radius: 4px;
  font-size: 12px;
  padding-left: 32px;
}
.sidebar-search-wrap { position: relative; }
.sidebar-search-wrap .bi-search {
  position: absolute; left: 10px; top: 50%;
  transform: translateY(-50%);
  color: #aaa; font-size: 13px;
}
.sidebar-filter-section {
  padding: 10px 12px;
  border-bottom: 1px solid #eee;
}
.sidebar-filter-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .1em;
  color: #99a;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.sidebar-filter-section select {
  font-size: 12px;
  font-weight: 600;
  padding: 5px 8px;
}
.sidebar-nav-link {
  display: block;
  padding: 10px 16px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .04em;
  color: #445;
  text-decoration: none;
  border-left: 3px solid transparent;
  text-transform: uppercase;
  transition: all .1s;
}
.sidebar-nav-link:hover { background: #f0f4ff; color: #003B71; }
.sidebar-nav-link.active {
  background: #e8f0fe;
  color: #003B71;
  border-left-color: #003B71;
  font-weight: 800;
}

/* ── Main content area ───────────────────────────────────────── */
.courses-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.courses-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 20px;
  background: #fff;
  border-bottom: 1px solid #ddd;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .04em;
  color: #445;
}
.btn-course-actions {
  background: #2c3e50;
  color: #fff;
  border: none;
  padding: 7px 18px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .06em;
  border-radius: 3px;
  cursor: pointer;
  transition: background .15s;
}
.btn-course-actions:hover { background: #1a252f; }

/* ── Course row ──────────────────────────────────────────────── */
.course-row {
  display: flex;
  align-items: center;
  padding: 0 20px;
  border-bottom: 1px solid #e8e8e8;
  background: #fff;
  min-height: 64px;
  transition: background .1s;
}
.course-row:hover { background: #fafcff; }
.course-row-expand {
  width: 28px;
  height: 28px;
  border: 2px solid #ccd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #89a;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  flex-shrink: 0;
  margin-right: 16px;
  transition: all .1s;
  background: none;
  text-decoration: none;
}
.course-row-expand:hover { border-color: #003B71; color: #003B71; }
.course-row-expand.expanded { background: #003B71; border-color: #003B71; color: #fff; }
.course-info { flex: 1; min-width: 0; }
.course-number {
  font-size: 15px;
  font-weight: 800;
  color: #222;
  letter-spacing: .02em;
}
.course-name-sub {
  font-size: 11px;
  color: #778;
  margin-top: 1px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 280px;
}
.section-count-badge {
  display: inline-flex;
  align-items: center;
  background: #3c4a5a;
  color: #fff;
  border-radius: 20px;
  padding: 2px 9px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .04em;
  margin-left: 8px;
  vertical-align: middle;
}
.course-badges {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-right: 20px;
}
.status-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 2px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .06em;
  white-space: nowrap;
}
.status-badge-pending  { background: #fff8e1; border: 1px solid #f9a825; color: #e65100; }
.status-badge-verified { background: #e3f2fd; border: 1px solid #1976d2; color: #0d47a1; }
.status-badge-approved { background: #e8f5e9; border: 1px solid #43a047; color: #1b5e20; }
.status-badge-rejected { background: #ffebee; border: 1px solid #e53935; color: #b71c1c; }
.status-badge-empty    { background: #f5f5f5; border: 1px solid #bbb;    color: #888;    font-style: italic; }
.btn-actions {
  background: #e8e8e8;
  border: none;
  padding: 7px 14px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .04em;
  color: #445;
  border-radius: 3px;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
  display: inline-block;
}
.btn-actions:hover { background: #d0d8e4; color: #003B71; }
.btn-actions i { font-size: 10px; }

/* ── Expanded sections panel ─────────────────────────────────── */
.course-sections-panel {
  background: #f8fafc;
  border-bottom: 1px solid #dde;
  padding: 12px 20px 12px 64px;
  display: none;
}
.course-sections-panel.show { display: block; }
.section-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #eef;
  gap: 12px;
  font-size: 12px;
}
.section-row:last-child { border-bottom: none; }
.section-row-number { font-weight: 700; color: #334; min-width: 80px; }
.section-row-name   { color: #556; flex: 1; }
.section-row-actions { display: flex; gap: 6px; }

/* ── Empty state ─────────────────────────────────────────────── */
.courses-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  color: #99a;
}
.courses-empty i { font-size: 3rem; margin-bottom: 16px; }
</style>

<!-- ── Status tab bar ────────────────────────────────────────────────── -->
<div class="courses-status-bar">
    <a class="status-tab @(currentFilter=="all"?"active":"")"
       href="@Url.Action(listAction,"Courses", new{filter="all",search=currentSearch,dept=currentDept})">
        <span class="tab-count">@cntTotal</span>@(isMyCourses?"MY COURSES":"ALL COURSES")
    </a>
    <a class="status-tab @(currentFilter=="pending"?"active":"")"
       href="@Url.Action(listAction,"Courses", new{filter="pending",search=currentSearch,dept=currentDept})">
        <span class="tab-count">@cntPending</span>INCOMPLETE
    </a>
    <a class="status-tab @(currentFilter=="verified"?"active":"")"
       href="@Url.Action(listAction,"Courses", new{filter="verified",search=currentSearch,dept=currentDept})">
        <span class="tab-count">@cntVerified</span>SUBMITTED
    </a>
    <a class="status-tab @(currentFilter=="approved"?"active":"")"
       href="@Url.Action(listAction,"Courses", new{filter="approved",search=currentSearch,dept=currentDept})">
        <span class="tab-count">@cntApproved</span>APPROVED
    </a>
    <a class="status-tab @(currentFilter=="rejected"?"active":"")"
       href="@Url.Action(listAction,"Courses", new{filter="rejected",search=currentSearch,dept=currentDept})">
        <span class="tab-count">@cntRejected</span>REJECTED
    </a>
</div>

<!-- ── Page body ─────────────────────────────────────────────────────── -->
<div class="courses-page-body">

    <!-- ── Left sidebar ────────────────────────────────────────────────── -->
    <div class="courses-sidebar">
        <!-- Filter tabs -->
        <div class="sidebar-filter-tabs">
            <a class="sf-tab active" href="#">QUICK FILTERS</a>
            <a class="sf-tab" href="#">ADVANCED</a>
        </div>

        <!-- Search -->
        <form method="get" action="@Url.Action(listAction, "Courses")" class="sidebar-search-box">
            <input type="hidden" name="filter" value="@currentFilter" />
            <input type="hidden" name="dept"   value="@currentDept" />
            <div class="sidebar-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@currentSearch"
                       class="form-control form-control-sm"
                       placeholder="Search for a course..." />
            </div>
        </form>

        <!-- Department filter -->
        <div class="sidebar-filter-section">
            <div class="sidebar-filter-label">Filter by Department</div>
            <select class="form-select form-select-sm"
                    onchange="window.location=this.value">
                @{
                    var allDeptUrl = Url.Action(listAction, "Courses", new { filter = currentFilter, search = currentSearch, dept = "ALL" });
                    var isAllSelected = string.IsNullOrEmpty(currentDept) || currentDept == "ALL";
                }
                @if (isAllSelected)
                {
                    <option value="@allDeptUrl" selected>ALL DEPARTMENTS</option>
                }
                else
                {
                    <option value="@allDeptUrl">ALL DEPARTMENTS</option>
                }
                @foreach (var d in departments)
                {
                    var deptUrl = Url.Action(listAction, "Courses", new { filter = currentFilter, search = currentSearch, dept = d });
                    if (currentDept == d)
                    {
                        <option value="@deptUrl" selected>@d</option>
                    }
                    else
                    {
                        <option value="@deptUrl">@d</option>
                    }
                }
            </select>
        </div>

        <!-- Section filters — role-conditional -->
        @if (isMyCourses)
        {
            <a class="sidebar-nav-link @(currentFilter=="all"?"active":"")"
               href="@Url.Action("MyCourses","Courses",new{filter="all"})">MY COURSES</a>
            <a class="sidebar-nav-link @(currentFilter=="pending"?"active":"")"
               href="@Url.Action("MyCourses","Courses",new{filter="pending"})">INCOMPLETE</a>
            <a class="sidebar-nav-link @(currentFilter=="approved"?"active":"")"
               href="@Url.Action("MyCourses","Courses",new{filter="approved"})">APPROVED</a>
            <a class="sidebar-nav-link @(currentFilter=="rejected"?"active":"")"
               href="@Url.Action("MyCourses","Courses",new{filter="rejected"})">REJECTED</a>
        }
        else
        {
            <a class="sidebar-nav-link @(currentFilter=="all"?"active":"")"
               href="@Url.Action("Index","Courses",new{filter="all"})">ALL SECTIONS</a>
            <a class="sidebar-nav-link @(currentFilter=="pending"?"active":"")"
               href="@Url.Action("Index","Courses",new{filter="pending"})">SECTIONS TO VERIFY</a>
            <a class="sidebar-nav-link @(currentFilter=="verified"?"active":"")"
               href="@Url.Action("Index","Courses",new{filter="verified"})">SECTIONS TO APPROVE</a>
            <a class="sidebar-nav-link @(currentFilter=="approved"?"active":"")"
               href="@Url.Action("Index","Courses",new{filter="approved"})">APPROVED SECTIONS</a>
            <a class="sidebar-nav-link @(currentFilter=="rejected"?"active":"")"
               href="@Url.Action("Index","Courses",new{filter="rejected"})">REJECTED SECTIONS</a>
        }
        <a class="sidebar-nav-link" asp-controller="Requests" asp-action="Submit">NEW SUBMISSION</a>
    </div>

    <!-- ── Main content ─────────────────────────────────────────────────── -->
    <div class="courses-main">
        <!-- List header -->
        <div class="courses-list-header">
            <span>VIEWING <strong>@Model.Count</strong> COURSE@(Model.Count!=1?"S":"")</span>
            <button class="btn-course-actions">
                <i class="bi bi-chevron-down me-1"></i>COURSE ACTIONS
            </button>
        </div>

        @if (!Model.Any())
        {
            <div class="courses-empty">
                <i class="bi bi-inbox"></i>
                <p class="fw-semibold">No courses found matching your filters.</p>
                <a asp-controller="Requests" asp-action="Submit" class="btn btn-byui mt-2">
                    <i class="bi bi-plus me-1"></i>Submit a New Request
                </a>
            </div>
        }
        else
        {
            @foreach (var group in Model)
            {
                var panelId = $"sections_{group.CourseNumber.Replace(" ", "_")}";
                var statusClass = group.HasNoRequest ? "status-badge-empty" :
                    group.OverallStatus switch {
                        RequestStatus.Approved => "status-badge-approved",
                        RequestStatus.Rejected => "status-badge-rejected",
                        RequestStatus.Verified => "status-badge-verified",
                        _                      => "status-badge-pending"
                    };
                var statusLabel = group.HasNoRequest ? "NO SUBMISSION YET" :
                    group.OverallStatus switch {
                        RequestStatus.Approved => "APPROVED",
                        RequestStatus.Rejected => "REJECTED",
                        RequestStatus.Verified => "VERIFIED",
                        _                      => "PENDING VERIFICATION"
                    };

                <div class="course-row">
                    <!-- Expand button (hidden for courses with no submissions) -->
                    @if (group.HasNoRequest)
                    {
                        <span class="course-row-expand" style="opacity:.3;cursor:default;" title="No sections yet">·</span>
                    }
                    else
                    {
                        <button class="course-row-expand" onclick="toggleSections('@panelId', this)"
                                title="Expand sections" type="button">+</button>
                    }

                    <!-- Course info -->
                    <div class="course-info">
                        <a class="course-number"
                           asp-controller="Courses" asp-action="Materials"
                           asp-route-course="@group.CourseNumber"
                           style="text-decoration:none;color:inherit;">
                            @group.CourseNumber
                        </a>
                        @if (group.HasNoRequest)
                        {
                            <span class="section-count-badge" style="background:#aaa;">NO SUBMISSION</span>
                        }
                        else
                        {
                            <span class="section-count-badge">
                                @group.Sections.Count SECTION@(group.Sections.Count!=1?"S":"")
                            </span>
                        }
                        <div class="course-name-sub">@group.CourseName</div>
                    </div>

                    <!-- Status badges -->
                    <div class="course-badges">
                        <span class="status-badge @statusClass">@statusLabel</span>
                        @{
                            var distinctStatuses = group.Sections
                                .Select(s => s.Status).Distinct().ToList();
                            if (distinctStatuses.Count > 1)
                            {
                                <span class="status-badge status-badge-pending" style="font-size:9px;">
                                    MIXED STATUSES
                                </span>
                            }
                        }
                    </div>

                    <!-- Actions -->
                    <div class="dropdown">
                        <a class="btn-actions dropdown-toggle" href="#"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            ACTIONS <i class="bi bi-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            @if (group.Sections.Count == 1)
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Requests"
                                       asp-action="Details"
                                       asp-route-id="@group.Sections[0].Id">
                                        <i class="bi bi-eye me-2"></i>View Details
                                    </a>
                                </li>
                            }
                            <li>
                                <a class="dropdown-item" asp-controller="Requests"
                                   asp-action="Submit">
                                    <i class="bi bi-plus-circle me-2"></i>Add New Section
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Expanded sections panel -->
                <div class="course-sections-panel" id="@panelId">
                    @foreach (var sec in group.Sections)
                    {
                        var secStatusClass = sec.Status switch {
                            RequestStatus.Approved => "status-badge-approved",
                            RequestStatus.Rejected => "status-badge-rejected",
                            RequestStatus.Verified => "status-badge-verified",
                            _                      => "status-badge-pending"
                        };
                        var secStatusLabel = sec.Status switch {
                            RequestStatus.Approved => "APPROVED",
                            RequestStatus.Rejected => "REJECTED",
                            RequestStatus.Verified => "VERIFIED",
                            _                      => "PENDING"
                        };
                        <div class="section-row">
                            <span class="section-row-number">
                                @sec.CourseNumber — Sec @(sec.Section ?? "—")
                            </span>
                            <span class="section-row-name">
                                @sec.CourseName
                                <span class="text-muted ms-2" style="font-size:10px;">
                                    @sec.Semester
                                </span>
                            </span>
                            <span class="status-badge @secStatusClass" style="font-size:10px;">
                                @secStatusLabel
                            </span>
                            <div class="section-row-actions">
                                <a asp-controller="Requests" asp-action="Details"
                                   asp-route-id="@sec.Id" class="btn btn-sm btn-outline-secondary py-0 px-2"
                                   style="font-size:10px;">VIEW</a>
                                @if (!isMyCourses && sec.Status == RequestStatus.PendingVerification)
                                {
                                    <a asp-controller="Requests" asp-action="Verify"
                                       asp-route-id="@sec.Id" class="btn btn-sm btn-outline-primary py-0 px-2"
                                       style="font-size:10px;">VERIFY</a>
                                }
                                @if (!isMyCourses && sec.Status == RequestStatus.Verified)
                                {
                                    <a asp-controller="Requests" asp-action="Approve"
                                       asp-route-id="@sec.Id" class="btn btn-sm btn-outline-success py-0 px-2"
                                       style="font-size:10px;">APPROVE</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div><!-- /courses-main -->
</div><!-- /courses-page-body -->

@section Scripts {
<script>
function toggleSections(panelId, btn) {
    const panel = document.getElementById(panelId);
    if (!panel) return;
    const isOpen = panel.classList.toggle('show');
    btn.classList.toggle('expanded', isOpen);
    btn.textContent = isOpen ? '−' : '+';
}
</script>
}
