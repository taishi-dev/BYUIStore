@model CampusAdoptions.Models.CourseRequest
@using CampusAdoptions.Models
@{
    var bookItems = Model.Items
        .Where(i => i.ItemType == ItemType.Book && !string.IsNullOrEmpty(i.Isbn))
        .ToList();
}

@if (bookItems.Any())
{
<div class="card mt-4" id="checklistCard">
  <div class="card-header d-flex align-items-center gap-2"
       style="background:#1a3a5c; color:#fff; padding:12px 18px;">
    <i class="bi bi-robot fs-5"></i>
    <strong style="font-size:14px; letter-spacing:.3px;">Automated Review Checklist</strong>
    <span class="badge bg-secondary ms-1">@bookItems.Count book(s)</span>
    <button type="button" id="btnRunChecks" onclick="runAllBookChecks()"
            class="btn btn-sm btn-outline-light ms-auto"
            style="font-size:11px; font-weight:700; letter-spacing:.3px;">
      <i class="bi bi-play-circle me-1"></i>RUN ALL CHECKS
    </button>
  </div>

  <div class="card-body p-0">
    @foreach (var item in bookItems)
    {
    <div class="checklist-book-row"
         id="clRow_@item.Isbn"
         data-isbn="@item.Isbn"
         data-course="@Model.CourseNumber"
         data-required="@item.IsRequired.ToString().ToLower()"
         data-request-id="@Model.Id"
         style="border-bottom:1px solid #e9ecef;">

      <!-- Book header bar -->
      <div style="padding:10px 16px; background:#f8f9fc; display:flex; align-items:center; gap:12px;">
        <div id="clThumb_@item.Isbn"
             style="width:80px; height:110px; background:#dee2e6; border-radius:4px;
                    flex-shrink:0; overflow:hidden; display:flex; align-items:center; justify-content:center;
                    border:1px solid #c8cdd2; box-shadow:0 1px 4px rgba(0,0,0,.1);">
          <i class="bi bi-book text-muted" style="font-size:22px;"></i>
        </div>
        <div style="flex:1; min-width:0;">
          <div style="font-weight:700; font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            @item.Title
          </div>
          <div style="font-size:11px; color:#6c757d;">
            @item.Author
            @if (!string.IsNullOrEmpty(item.Author) && !string.IsNullOrEmpty(item.Isbn)) { <text> · </text> }
            ISBN: <code style="color:#198754;">@item.Isbn</code>
          </div>
        </div>
        <div id="clStatus_@item.Isbn">
          <span class="badge bg-secondary" style="font-size:11px;">
            <i class="bi bi-hourglass me-1"></i>Waiting
          </span>
        </div>
      </div>

      <!-- 4-item checklist grid (hidden until results arrive) -->
      <div id="clBody_@item.Isbn" style="display:none; padding:12px 16px;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">

          <!-- ① Still available -->
          <div id="clAvail_@item.Isbn" class="cl-item">
            <div class="cl-label"><i class="bi bi-shop me-1"></i>Still Available to Buy</div>
            <div class="cl-value cl-spin"><i class="bi bi-hourglass-split"></i></div>
          </div>

          <!-- ② Price -->
          <div id="clPrice_@item.Isbn" class="cl-item">
            <div class="cl-label"><i class="bi bi-currency-dollar me-1"></i>Current Price</div>
            <div class="cl-value cl-spin"><i class="bi bi-hourglass-split"></i></div>
          </div>

          <!-- ③ Digital availability -->
          <div id="clDigital_@item.Isbn" class="cl-item">
            <div class="cl-label"><i class="bi bi-tablet me-1"></i>Digital Version (eBook)</div>
            <div class="cl-value cl-spin"><i class="bi bi-hourglass-split"></i></div>
          </div>

          <!-- ④ Required / Optional change -->
          <div id="clReq_@item.Isbn" class="cl-item">
            <div class="cl-label"><i class="bi bi-arrow-left-right me-1"></i>Required / Optional Status</div>
            <div class="cl-value cl-spin"><i class="bi bi-hourglass-split"></i></div>
          </div>

        </div>
      </div>

    </div><!-- /clRow -->
    }
  </div><!-- /card-body -->
</div><!-- /card -->

<style>
.cl-item {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  padding: 10px 12px;
}
.cl-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #6b7280;
  margin-bottom: 5px;
}
.cl-value { font-size: 12px; font-weight: 600; line-height: 1.4; }
.cl-spin  { color: #9ca3af; }
.cl-ok    { color: #15803d; }
.cl-warn  { color: #b45309; }
.cl-bad   { color: #b91c1c; }
.cl-unk   { color: #6b7280; }
.cl-flag  { background: #fef2f2 !important; border-color: #fca5a5 !important; }
.cl-caution { background: #fffbeb !important; border-color: #fde68a !important; }
</style>

<script>
// Auto-run immediately when this partial loads
document.addEventListener('DOMContentLoaded', () => runAllBookChecks());

async function runAllBookChecks() {
  const btn = document.getElementById('btnRunChecks');
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>CHECKING…';
  }

  const rows = document.querySelectorAll('.checklist-book-row');
  await Promise.all(Array.from(rows).map(row => runBookCheck(row)));

  if (btn) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>RE-CHECK ALL';
  }
}

async function runBookCheck(row) {
  const isbn      = row.dataset.isbn;
  const course    = row.dataset.course;
  const required  = row.dataset.required;       // "true" / "false"
  const reqId     = row.dataset.requestId;
  const statusEl  = document.getElementById(`clStatus_${isbn}`);
  const bodyEl    = document.getElementById(`clBody_${isbn}`);

  if (statusEl) statusEl.innerHTML =
    '<span class="badge bg-info text-dark" style="font-size:11px;"><i class="bi bi-hourglass-split me-1"></i>Checking…</span>';

  try {
    const url = `/api/book-checklist?isbn=${encodeURIComponent(isbn)}`
              + `&courseNumber=${encodeURIComponent(course)}`
              + `&isRequired=${required}`
              + `&requestId=${reqId}`;
    const res = await fetch(url);
    if (!res.ok) throw new Error('API error ' + res.status);
    const d = await res.json();

    if (bodyEl) bodyEl.style.display = '';

    // ── ① Still available ────────────────────────────────────────────────
    const availEl = document.getElementById(`clAvail_${isbn}`);
    if (availEl) {
      const v = availEl.querySelector('.cl-value');
      if (d.printAvailable) {
        v.className = 'cl-value cl-ok';
        v.innerHTML = `<i class="bi bi-check-circle-fill me-1"></i>Available to purchase`
          + `<div style="font-size:11px;font-weight:400;margin-top:3px;">`
          + `<a href="${d.amazonUrl}" target="_blank" style="color:#c45500;"><i class="bi bi-box-arrow-up-right me-1"></i>Amazon</a>`
          + (d.googleBuyLink ? ` &nbsp;|&nbsp; <a href="${d.googleBuyLink}" target="_blank" style="color:#4285f4;"><i class="bi bi-box-arrow-up-right me-1"></i>Google Books</a>` : '')
          + `</div>`;
      } else {
        v.className = 'cl-value cl-warn';
        v.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-1"></i>Not confirmed in catalog`
          + `<div style="font-size:11px;font-weight:400;margin-top:3px;">`
          + `<a href="${d.amazonUrl}" target="_blank" style="color:#c45500;"><i class="bi bi-box-arrow-up-right me-1"></i>Verify on Amazon</a></div>`;
      }
    }

    // ── ② Price ─────────────────────────────────────────────────────────
    const priceEl = document.getElementById(`clPrice_${isbn}`);
    if (priceEl) {
      const v = priceEl.querySelector('.cl-value');
      if (d.printPrice != null) {
        const p = parseFloat(d.printPrice);
        if (d.priceFlagged) {
          v.className = 'cl-value cl-bad';
          v.innerHTML = `<i class="bi bi-exclamation-octagon-fill me-1"></i>$${p.toFixed(2)} — HIGH PRICE`
            + `<div style="font-size:11px;font-weight:400;color:#b91c1c;margin-top:3px;">`
            + `⚠ Exceeds $100. Please contact the professor to confirm this is the correct book/edition.</div>`;
          priceEl.classList.add('cl-flag');
        } else {
          v.className = 'cl-value cl-ok';
          v.innerHTML = `<i class="bi bi-check-circle-fill me-1"></i>$${p.toFixed(2)}`;
        }
      } else {
        v.className = 'cl-value cl-unk';
        v.innerHTML = `<i class="bi bi-question-circle me-1"></i>Price not found online`
          + `<div style="font-size:11px;font-weight:400;margin-top:3px;">`
          + `<a href="${d.amazonUrl}" target="_blank" style="color:#c45500;">Check current price on Amazon ↗</a></div>`;
      }
    }

    // ── ③ Digital availability ───────────────────────────────────────────
    const digitalEl = document.getElementById(`clDigital_${isbn}`);
    if (digitalEl) {
      const v = digitalEl.querySelector('.cl-value');
      if (d.digitalOnVitalSource) {
        v.className = 'cl-value cl-ok';
        v.innerHTML = `<i class="bi bi-check-circle-fill me-1"></i>Available on VitalSource`
          + `<div style="font-size:11px;font-weight:400;margin-top:3px;">`
          + `<a href="${d.vitalSourceUrl}" target="_blank" style="color:#0d6efd;"><i class="bi bi-box-arrow-up-right me-1"></i>View on VitalSource</a></div>`;
      } else if (d.digitalOnGoogle) {
        v.className = 'cl-value cl-warn';
        v.innerHTML = `<i class="bi bi-exclamation-circle-fill me-1"></i>eBook on Google Books (not VitalSource)`
          + `<div style="font-size:11px;font-weight:400;margin-top:3px;">`
          + (d.googleBuyLink ? `<a href="${d.googleBuyLink}" target="_blank" style="color:#4285f4;">Google Books ↗</a> &nbsp;|&nbsp; ` : '')
          + `<a href="${d.vitalSourceUrl}" target="_blank" style="color:#0d6efd;">Search VitalSource ↗</a></div>`;
        digitalEl.classList.add('cl-caution');
      } else {
        v.className = 'cl-value cl-bad';
        v.innerHTML = `<i class="bi bi-x-circle-fill me-1"></i>No digital version found`
          + `<div style="font-size:11px;font-weight:400;color:#b91c1c;margin-top:3px;">`
          + `Contact the publisher for digital distribution rights, or check if another university has used it on `
          + `<a href="${d.vitalSourceUrl}" target="_blank" style="color:#0d6efd;">VitalSource ↗</a>.</div>`;
        digitalEl.classList.add('cl-flag');
      }
    }

    // ── ④ Required / Optional change ────────────────────────────────────
    const reqEl = document.getElementById(`clReq_${isbn}`);
    if (reqEl) {
      const v     = reqEl.querySelector('.cl-value');
      const curr  = required === 'true' ? 'REQUIRED' : 'OPTIONAL';
      if (d.requiredChanged && d.previousSemester) {
        const prev = d.previousIsRequired ? 'REQUIRED' : 'OPTIONAL';
        v.className = 'cl-value cl-warn';
        v.innerHTML = `<i class="bi bi-arrow-left-right me-1"></i>${prev} → ${curr}`
          + `<div style="font-size:11px;font-weight:400;color:#b45309;margin-top:3px;">`
          + `⚠ Was <strong>${prev}</strong> in <em>${d.previousSemester}</em>. `
          + `Now marked <strong>${curr}</strong>. Please confirm with the professor.</div>`;
        reqEl.classList.add('cl-caution');
      } else if (d.previousSemester) {
        v.className = 'cl-value cl-ok';
        v.innerHTML = `<i class="bi bi-check-circle-fill me-1"></i>${curr}`
          + ` <span style="font-weight:400;color:#6b7280;font-size:11px;">(same as ${d.previousSemester})</span>`;
      } else {
        v.className = 'cl-value cl-unk';
        v.innerHTML = `<i class="bi bi-info-circle me-1"></i>${curr}`
          + ` <span style="font-weight:400;color:#6b7280;font-size:11px;">(first time this book is used here)</span>`;
      }
    }

    // ── Cover thumbnail ──────────────────────────────────────────────────
    if (d.coverThumbnail) {
      const thumb = document.getElementById(`clThumb_${isbn}`);
      if (thumb) thumb.innerHTML =
        `<img src="${d.coverThumbnail}"
              style="width:100%;height:100%;object-fit:cover;"
              alt="Cover"
              onerror="this.parentElement.innerHTML='<i class=\\'bi bi-book text-muted\\' style=\\'font-size:22px;\\'></i>'"/>`;
    }

    // ── Overall status badge ─────────────────────────────────────────────
    if (statusEl) {
      const hasFlag  = d.priceFlagged || (!d.digitalOnVitalSource && !d.digitalOnGoogle);
      const hasCaution = d.requiredChanged || (!d.digitalOnVitalSource && d.digitalOnGoogle);
      if (hasFlag) {
        statusEl.innerHTML =
          '<span class="badge bg-danger" style="font-size:11px;"><i class="bi bi-exclamation-circle-fill me-1"></i>Needs Attention</span>';
      } else if (hasCaution) {
        statusEl.innerHTML =
          '<span class="badge bg-warning text-dark" style="font-size:11px;"><i class="bi bi-exclamation-triangle-fill me-1"></i>Review Suggested</span>';
      } else {
        statusEl.innerHTML =
          '<span class="badge bg-success" style="font-size:11px;"><i class="bi bi-check-circle-fill me-1"></i>All Clear</span>';
      }
    }

  } catch(e) {
    if (statusEl) statusEl.innerHTML =
      '<span class="badge bg-danger" style="font-size:11px;"><i class="bi bi-exclamation-triangle me-1"></i>Check Failed</span>';
    if (bodyEl) {
      bodyEl.style.display = '';
      bodyEl.innerHTML =
        '<div class="text-danger p-3" style="font-size:12px;">'
        + '<i class="bi bi-exclamation-triangle me-1"></i>'
        + 'Could not run automated checks. Please verify the items above manually.</div>';
    }
  }
}
</script>
}
