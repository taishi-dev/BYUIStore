@model CampusAdoptions.ViewModels.LoginViewModel
@{
    Layout = null; // standalone page - no layout
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In — BYUI University Store</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="verba-login-page">
  <div class="login-card">
    <!-- Brand -->
    <div class="login-brand">
      <div class="d-flex align-items-baseline justify-content-center gap-2">
        <span class="brand-byu" style="font-size:36px;font-weight:800;color:#1c2236;">BYU</span>
        <span style="font-size:9px;font-weight:600;letter-spacing:3px;color:#889;text-transform:uppercase;">IDAHO</span>
      </div>
      <div style="width:60%;margin:6px auto;border-top:1px solid #dde;"></div>
      <span class="brand-store-name" style="font-size:11px;color:#667;letter-spacing:2px;display:block;text-align:center;text-transform:uppercase;font-weight:600;">
        UNIVERSITY STORE
      </span>
    </div>

    <h2 style="font-size:15px;font-weight:700;color:#334;text-align:center;letter-spacing:.5px;margin-bottom:22px;">
      VERBA COLLECT
    </h2>

    @if (!ViewData.ModelState.IsValid)
    {
      <div class="alert alert-danger py-2 px-3" style="font-size:12px;">
        <i class="bi bi-exclamation-triangle me-1"></i>
        Invalid username or password.
      </div>
    }

    <form asp-action="Login" method="post">
      <div class="mb-3">
        <label asp-for="Username" class="form-label" style="font-size:11px;font-weight:700;letter-spacing:.5px;color:#556;text-transform:uppercase;">Username</label>
        <input asp-for="Username" class="form-control form-control-sm"
               placeholder="Enter your username" autocomplete="username" />
      </div>
      <div class="mb-4">
        <label asp-for="Password" class="form-label" style="font-size:11px;font-weight:700;letter-spacing:.5px;color:#556;text-transform:uppercase;">Password</label>
        <input asp-for="Password" type="password" class="form-control form-control-sm"
               placeholder="Enter your password" autocomplete="current-password" />
      </div>
      <button type="submit" class="btn btn-primary w-100"
              style="background:#1c2236;border-color:#1c2236;font-weight:700;letter-spacing:.8px;font-size:12px;">
        SIGN IN
      </button>
    </form>

    <div style="margin-top:24px;font-size:10px;color:#aab;text-align:center;letter-spacing:.3px;">
      Demo accounts — all use password: <strong>byui1234</strong><br/>
      <code style="font-size:10px;">prof_smith</code> · <code>coord_lee</code> · <code>manager_jones</code> · <code>staff_brown</code>
    </div>
  </div>

  <div style="margin-top:20px;font-size:10px;color:#445;letter-spacing:.3px;">
    © 2026 VERBA | VITALSOURCE &nbsp;·&nbsp;
    <a href="#" style="color:#667;">Privacy Policy</a>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
