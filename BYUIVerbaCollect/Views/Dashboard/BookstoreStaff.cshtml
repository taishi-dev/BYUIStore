@using BYUIVerbaCollect.Models
@{
    ViewData["Title"] = "Bookstore Staff Dashboard";
    var verified = ViewBag.VerifiedRequests as List<CourseRequest> ?? new();
    var all      = ViewBag.AllRequests      as List<CourseRequest> ?? new();
}

<div class="page-header">
  <h2><i class="bi bi-shop me-2"></i>Bookstore Staff Dashboard</h2>
  <p class="mb-0 opacity-75">Verify incoming requests and approve final orders</p>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-patch-check fs-2 text-info"></i>
      <div class="display-6 fw-bold mt-1">@verified.Count</div>
      <small class="text-muted">Ready to Approve</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-check-circle fs-2 text-success"></i>
      <div class="display-6 fw-bold mt-1">@all.Count(r => r.Status == RequestStatus.Approved)</div>
      <small class="text-muted">Approved</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-hourglass-split fs-2 text-warning"></i>
      <div class="display-6 fw-bold mt-1">@all.Count(r => r.Status == RequestStatus.PendingVerification)</div>
      <small class="text-muted">Pending</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-upc-scan fs-2 text-primary"></i>
      <div class="display-6 fw-bold mt-1">@all.SelectMany(r => r.Items).Count(i => i.ItemType == ItemType.Book && !string.IsNullOrEmpty(i.Isbn))</div>
      <small class="text-muted">ISBNs Collected</small>
    </div>
  </div>
</div>

<!-- Ready to Approve -->
<div class="card mb-4">
  <div class="card-header card-header-byui">
    <i class="bi bi-patch-check me-2"></i>Verified — Ready for Approval
    <span class="badge bg-info text-dark ms-2">@verified.Count</span>
  </div>
  @if (!verified.Any())
  {
    <div class="card-body text-center text-muted py-4">
      <i class="bi bi-inbox fs-3"></i><br/>No verified requests waiting for approval.
    </div>
  }
  else
  {
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>#</th><th>Course</th><th>Submitted By</th><th>Verified By</th><th>Books</th><th>Supplies</th><th></th></tr>
        </thead>
        <tbody>
          @foreach (var req in verified)
          {
            <tr>
              <td class="text-muted small">@req.Id</td>
              <td><strong>@req.CourseNumber</strong> — @req.CourseName<br/><small class="text-muted">@req.Semester</small></td>
              <td>@req.Submitter?.FullName</td>
              <td>@req.VerifiedBy?.FullName</td>
              <td><span class="badge bg-primary">@req.Items.Count(i => i.ItemType == ItemType.Book)</span></td>
              <td><span class="badge bg-secondary">@req.Items.Count(i => i.ItemType == ItemType.Supply)</span></td>
              <td class="d-flex gap-1">
                <a asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id"
                   class="btn btn-outline-byui btn-sm"><i class="bi bi-eye"></i></a>
                <a asp-controller="Requests" asp-action="Verify" asp-route-id="@req.Id"
                   class="btn btn-outline-info btn-sm"><i class="bi bi-shield-check"></i> Verify</a>
                <a asp-controller="Requests" asp-action="Approve" asp-route-id="@req.Id"
                   class="btn btn-success btn-sm"><i class="bi bi-check-circle me-1"></i>Approve</a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

<!-- All Requests -->
<div class="card">
  <div class="card-header card-header-byui">
    <i class="bi bi-archive me-2"></i>All Requests
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr><th>#</th><th>Course</th><th>Submitted By</th><th>Semester</th><th>Status</th><th>Date</th><th></th></tr>
      </thead>
      <tbody>
        @foreach (var req in all)
        {
          <tr>
            <td class="text-muted small">@req.Id</td>
            <td><strong>@req.CourseNumber</strong><br/><small class="text-muted">@req.CourseName</small></td>
            <td>@req.Submitter?.FullName</td>
            <td>@req.Semester</td>
            <td><span class="badge status-badge-@req.Status.ToString().ToLower()">@req.Status.ToString().SplitCamelCase()</span></td>
            <td class="small text-muted">@req.SubmittedAt.ToString("MMM d, yyyy")</td>
            <td>
              <a asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id"
                 class="btn btn-outline-byui btn-sm"><i class="bi bi-eye me-1"></i>View</a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
