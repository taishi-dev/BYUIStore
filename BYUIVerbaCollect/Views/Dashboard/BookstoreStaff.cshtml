@using BYUIVerbaCollect.Models
@{
    ViewData["Title"]     = "Courses";
    ViewData["PageTitle"] = "COURSES";
    var verified  = ViewBag.VerifiedRequests as List<CourseRequest> ?? new();
    var all       = ViewBag.AllRequests      as List<CourseRequest> ?? new();
    var pending   = all.Where(r => r.Status == RequestStatus.PendingVerification).ToList();
    var approved  = all.Where(r => r.Status == RequestStatus.Approved).ToList();
    var activeFilter = Context.Request.Query["filter"].ToString() is { Length: > 0 } f ? f : "all";
    var searchTerm   = Context.Request.Query["search"].ToString();

    var displayed = activeFilter switch {
        "approve"  => verified,
        "pending"  => pending,
        "approved" => approved,
        _          => all
    };
    if (!string.IsNullOrWhiteSpace(searchTerm))
        displayed = displayed.Where(r =>
            r.CourseNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            r.CourseName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
}

<!-- ═══ Status Tab Bar ═══ -->
<div class="verba-status-tabs">
  <a class="status-tab @(activeFilter=="pending"  ? "active" : "")"
     href="?filter=pending">
    <span class="tab-count">@pending.Count</span> INCOMPLETE
  </a>
  <a class="status-tab @(activeFilter=="all"  ? "active" : "")"
     href="?filter=all">
    <span class="tab-count">@all.Count</span> SUBMITTED
  </a>
  <a class="status-tab @(activeFilter=="approve" ? "active" : "")"
     href="?filter=approve">
    <span class="tab-count">@verified.Count</span> REVIEWED
  </a>
  <a class="status-tab @(activeFilter=="approved" ? "active" : "")"
     href="?filter=approved">
    <span class="tab-count approved-count">@approved.Count</span> APPROVED
  </a>
</div>

<!-- ═══ Main Body: Sidebar + Course List ═══ -->
<div class="verba-main-layout">

  <!-- Left Sidebar -->
  <aside class="verba-sidebar">
    <!-- Quick / Advanced filter tabs -->
    <div class="sidebar-filter-tabs">
      <button class="sf-tab active">QUICK FILTERS</button>
      <button class="sf-tab">ADVANCED</button>
    </div>

    <!-- Search -->
    <div class="sidebar-search-wrap">
      <form method="get" action="">
        <input type="hidden" name="filter" value="@activeFilter" />
        <div class="sidebar-search-box">
          <input class="sidebar-search-input" name="search" value="@searchTerm"
                 placeholder="Search for a course..." />
          <button class="sidebar-search-btn" type="submit"><i class="bi bi-search"></i></button>
        </div>
      </form>
    </div>

    <!-- Filter by Department -->
    <div class="sidebar-filter-group">
      <label class="sidebar-filter-label">FILTER BY DEPARTMENT</label>
      <select class="form-select form-select-sm sidebar-select">
        <option>ALL DEPARTMENTS</option>
        <option>Computer Science</option>
        <option>Business</option>
        <option>Mathematics</option>
        <option>English</option>
      </select>
    </div>

    <!-- Filter by User -->
    <div class="sidebar-filter-group">
      <label class="sidebar-filter-label">FILTER BY USER</label>
      <select class="form-select form-select-sm sidebar-select">
        <option>ALL USERS</option>
        @foreach (var u in all.Select(r => r.Submitter?.FullName).Distinct())
        {
          <option>@u</option>
        }
      </select>
    </div>

    <!-- Section type quick links -->
    <nav class="sidebar-section-nav">
      <a class="ssnav-link @(activeFilter=="all"     ? "active" : "")" href="?filter=all">ALL SECTIONS</a>
      <a class="ssnav-link" href="#">SECTIONS TO EMAIL</a>
      <a class="ssnav-link @(activeFilter=="approve" ? "active" : "")" href="?filter=approve">SECTIONS TO APPROVE</a>
      <a class="ssnav-link" href="#">NEW SECTIONS TO PUSH</a>
      <a class="ssnav-link" href="#">SECTIONS TO PRINT/EXPORT</a>
      <a class="ssnav-link" href="#">AUTO ACCESS INTEREST</a>
      <a class="ssnav-link" href="#">NO TEXT REQUIRED</a>
      <a class="ssnav-link" href="#">SECTIONS WITH MESSAGES</a>
    </nav>
  </aside>

  <!-- Course List -->
  <section class="verba-course-list">

    <!-- Toolbar -->
    <div class="course-list-toolbar">
      <span class="courses-count-label">VIEWING @displayed.Count COURSES</span>
      <div class="dropdown">
        <button class="btn btn-dark btn-sm dropdown-toggle course-actions-btn" type="button"
                data-bs-toggle="dropdown">
          COURSE ACTIONS
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="#">Export Selected</a></li>
          <li><a class="dropdown-item" href="#">Mark as Reviewed</a></li>
          <li><a class="dropdown-item" asp-controller="Availability" asp-action="Index">Book Availability Report</a></li>
        </ul>
      </div>
    </div>

    <!-- Rows -->
    @if (!displayed.Any())
    {
      <div class="no-courses-msg">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No courses match the current filter.
      </div>
    }
    else
    {
      @foreach (var req in displayed)
      {
        var isApproved = req.Status == RequestStatus.Approved;
        var isVerified = req.Status == RequestStatus.Verified;
        var hasSections = req.Items.Any();

        <div class="course-row" data-id="@req.Id">
          <!-- Expand icon -->
          <div class="course-row-expander">
            @if (hasSections)
            {
              <span class="dot-menu">● ● ●</span>
            }
            else
            {
              <button class="expand-btn" onclick="toggleSection(this)">
                <i class="bi bi-plus-lg"></i>
              </button>
            }
          </div>

          <!-- Course info -->
          <div class="course-row-info">
            <a class="course-number" asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id">
              @req.CourseNumber
            </a>
            @if (req.Items.Any())
            {
              <span class="sections-count-badge">@req.Items.Count ITEM@(req.Items.Count != 1 ? "S" : "")</span>
            }
            else
            {
              <span class="sections-count-badge">@req.Semester</span>
            }
            <div class="course-row-subtext">
              @req.Submitter?.FullName (@req.Section ?? "01")
            </div>
          </div>

          <!-- Status badges -->
          <div class="course-row-badges">
            @if (isApproved)
            {
              <span class="badge-exported">CURRENT SINCE EXPORTED</span>
            }
            else if (isVerified)
            {
              <span class="badge-reviewed">REVIEWED</span>
            }
            else
            {
              <span class="badge-not-exported">NOT YET EXPORTED</span>
            }
            <span class="badge-not-pushed ms-1">NOT YET PUSHED</span>
          </div>

          <!-- Actions -->
          <div class="course-row-actions">
            <div class="dropdown">
              <button class="btn btn-sm btn-outline-secondary dropdown-toggle actions-dropdown-btn"
                      type="button" data-bs-toggle="dropdown">
                ACTIONS
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <a class="dropdown-item" asp-controller="Requests" asp-action="Details"
                     asp-route-id="@req.Id">
                    <i class="bi bi-eye me-2"></i>View Details
                  </a>
                </li>
                @if (req.Status == RequestStatus.PendingVerification)
                {
                  <li>
                    <a class="dropdown-item" asp-controller="Requests" asp-action="Verify"
                       asp-route-id="@req.Id">
                      <i class="bi bi-shield-check me-2"></i>Verify
                    </a>
                  </li>
                }
                @if (isVerified)
                {
                  <li>
                    <a class="dropdown-item text-success" asp-controller="Requests" asp-action="Approve"
                       asp-route-id="@req.Id">
                      <i class="bi bi-check-circle me-2"></i>Approve
                    </a>
                  </li>
                }
              </ul>
            </div>
          </div>
        </div>
      }
    }

    <!-- Pagination -->
    <nav class="verba-pagination">
      <span class="page-btn disabled">‹ PREV</span>
      <span class="page-btn active">1</span>
      <span class="page-btn">2</span>
      <span class="page-btn">3</span>
      <span class="page-ellipsis">…</span>
      <span class="page-btn">›› NEXT</span>
      <span class="page-jump-label ms-4">JUMP TO PAGE</span>
      <input class="page-jump-input" type="number" value="1" min="1" />
      <button class="page-jump-go">GO</button>
    </nav>

  </section>
</div>

@section Scripts {
<script>
function toggleSection(btn) {
  var icon = btn.querySelector('i');
  icon.classList.toggle('bi-plus-lg');
  icon.classList.toggle('bi-dash-lg');
}
</script>
}
