@model List<BYUIVerbaCollect.Models.CourseRequest>
@using BYUIVerbaCollect.Models
@{ ViewData["Title"] = "My Requests"; }

<div class="page-header d-flex justify-content-between align-items-center">
  <div>
    <h2><i class="bi bi-person-workspace me-2"></i>My Course Requests</h2>
    <p class="mb-0 opacity-75">Submit and track your book &amp; supply requests for VERBA COLLECT</p>
  </div>
  <a asp-controller="Requests" asp-action="Submit" class="btn btn-gold btn-lg">
    <i class="bi bi-plus-circle me-2"></i>New Request
  </a>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
  @foreach (var (label, icon, color, status) in new[] {
    ("Pending Verification", "bi-hourglass-split", "warning", RequestStatus.PendingVerification),
    ("Verified",             "bi-patch-check",     "info",    RequestStatus.Verified),
    ("Approved",             "bi-check-circle",    "success", RequestStatus.Approved),
    ("Rejected",             "bi-x-circle",        "danger",  RequestStatus.Rejected),
  })
  {
    <div class="col-6 col-md-3">
      <div class="card stat-card text-center p-3">
        <i class="bi @icon fs-2 text-@color"></i>
        <div class="display-6 fw-bold mt-1">@Model.Count(r => r.Status == status)</div>
        <small class="text-muted">@label</small>
      </div>
    </div>
  }
</div>

<!-- Requests table -->
@if (!Model.Any())
{
  <div class="card p-5 text-center">
    <i class="bi bi-inbox fs-1 text-muted"></i>
    <h4 class="mt-3 text-muted">No requests yet</h4>
    <p class="text-muted">Click <strong>New Request</strong> to submit your first book/supply list.</p>
  </div>
}
else
{
  <div class="card">
    <div class="card-header card-header-byui d-flex align-items-center">
      <i class="bi bi-list-ul me-2"></i>All My Requests
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Course</th>
            <th>Semester</th>
            <th>Items</th>
            <th>Status</th>
            <th>Submitted</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var req in Model)
          {
            <tr>
              <td class="text-muted small">@req.Id</td>
              <td>
                <strong>@req.CourseNumber</strong><br />
                <small class="text-muted">@req.CourseName</small>
              </td>
              <td>@req.Semester</td>
              <td><span class="badge bg-secondary">@req.Items.Count item(s)</span></td>
              <td><span class="badge status-badge-@req.Status.ToString().ToLower()">@req.Status.ToString().SplitCamelCase()</span></td>
              <td class="small text-muted">@req.SubmittedAt.ToString("MMM d, yyyy")</td>
              <td>
                <a asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id"
                   class="btn btn-outline-byui btn-sm">
                  <i class="bi bi-eye me-1"></i>View
                </a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
