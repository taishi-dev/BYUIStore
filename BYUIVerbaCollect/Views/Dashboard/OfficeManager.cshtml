@using BYUIVerbaCollect.Models
@{
    ViewData["Title"] = "Office Manager Dashboard";
    var pending      = ViewBag.PendingRequests  as List<CourseRequest> ?? new();
    var mySubmissions= ViewBag.MySubmissions     as List<CourseRequest> ?? new();
    var all          = ViewBag.AllRequests       as List<CourseRequest> ?? new();
}

<div class="page-header d-flex justify-content-between align-items-center">
  <div>
    <h2><i class="bi bi-clipboard2-check me-2"></i>Office Manager Dashboard</h2>
    <p class="mb-0 opacity-75">Review incoming requests and submit your own</p>
  </div>
  <a asp-controller="Requests" asp-action="Submit" class="btn btn-gold btn-lg">
    <i class="bi bi-plus-circle me-2"></i>New Request
  </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-hourglass-split fs-2 text-warning"></i>
      <div class="display-6 fw-bold mt-1">@pending.Count</div>
      <small class="text-muted">Awaiting Verification</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-patch-check fs-2 text-info"></i>
      <div class="display-6 fw-bold mt-1">@all.Count(r => r.Status == RequestStatus.Verified)</div>
      <small class="text-muted">Verified</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-check-circle fs-2 text-success"></i>
      <div class="display-6 fw-bold mt-1">@all.Count(r => r.Status == RequestStatus.Approved)</div>
      <small class="text-muted">Approved</small>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card text-center p-3">
      <i class="bi bi-list-task fs-2 text-primary"></i>
      <div class="display-6 fw-bold mt-1">@all.Count</div>
      <small class="text-muted">Total Requests</small>
    </div>
  </div>
</div>

<!-- Pending Verification -->
<div class="card mb-4">
  <div class="card-header card-header-byui">
    <i class="bi bi-hourglass-split me-2"></i>Requests Awaiting Verification
    <span class="badge bg-warning text-dark ms-2">@pending.Count</span>
  </div>
  @if (!pending.Any())
  {
    <div class="card-body text-center text-muted py-4">
      <i class="bi bi-check2-all fs-3"></i><br/>All caught up — no pending requests.
    </div>
  }
  else
  {
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>#</th><th>Course</th><th>Submitted By</th><th>Semester</th><th>Items</th><th>Date</th><th></th></tr>
        </thead>
        <tbody>
          @foreach (var req in pending)
          {
            <tr>
              <td class="text-muted small">@req.Id</td>
              <td><strong>@req.CourseNumber</strong> — @req.CourseName</td>
              <td>@req.Submitter?.FullName</td>
              <td>@req.Semester</td>
              <td><span class="badge bg-secondary">@req.Items.Count</span></td>
              <td class="small text-muted">@req.SubmittedAt.ToString("MMM d, yyyy")</td>
              <td>
                <a asp-controller="Requests" asp-action="Verify" asp-route-id="@req.Id"
                   class="btn btn-byui btn-sm">
                  <i class="bi bi-shield-check me-1"></i>Verify
                </a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

<!-- All Requests History -->
<div class="card">
  <div class="card-header card-header-byui">
    <i class="bi bi-archive me-2"></i>All Requests
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr><th>#</th><th>Course</th><th>Submitted By</th><th>Semester</th><th>Status</th><th>Date</th><th></th></tr>
      </thead>
      <tbody>
        @foreach (var req in all)
        {
          <tr>
            <td class="text-muted small">@req.Id</td>
            <td><strong>@req.CourseNumber</strong><br/><small class="text-muted">@req.CourseName</small></td>
            <td>@req.Submitter?.FullName</td>
            <td>@req.Semester</td>
            <td><span class="badge status-badge-@req.Status.ToString().ToLower()">@req.Status.ToString().SplitCamelCase()</span></td>
            <td class="small text-muted">@req.SubmittedAt.ToString("MMM d, yyyy")</td>
              <td class="d-flex gap-1 flex-wrap">
                <a asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id"
                   class="btn btn-outline-byui btn-sm"><i class="bi bi-eye me-1"></i>View</a>
                <form method="post" asp-controller="Requests" asp-action="DeleteRequest"
                      asp-route-id="@req.Id" style="display:inline;margin:0;"
                      onsubmit="return confirm('Delete course request #@req.Id (@req.CourseNumber)?\nThis cannot be undone.')">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
