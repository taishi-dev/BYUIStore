@model BYUIVerbaCollect.Models.CourseRequest
@using BYUIVerbaCollect.Models
@{ ViewData["Title"] = $"Request #{Model.Id}"; }

<div class="d-flex justify-content-between align-items-start mb-3">
  <div class="page-header flex-grow-1 me-3">
    <h2><i class="bi bi-file-text me-2"></i>Request #@Model.Id</h2>
    <p class="mb-0 opacity-75">@Model.CourseNumber — @Model.CourseName (@Model.Semester)</p>
  </div>
  <div class="mt-2">
    <span class="badge status-badge-@Model.Status.ToString().ToLower() fs-6">
      @Model.Status.ToString().SplitCamelCase()
    </span>
  </div>
</div>

@await Html.PartialAsync("_RequestDetails", Model)

@if (Model.RejectionNote is not null)
{
  <div class="alert alert-danger mt-3">
    <i class="bi bi-x-circle-fill me-2"></i><strong>Rejection Note:</strong> @Model.RejectionNote
  </div>
}

<div class="mt-3">
  <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
  </a>
</div>
