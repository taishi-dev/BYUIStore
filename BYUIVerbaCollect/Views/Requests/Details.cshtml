@model CourseRequest
@{
    ViewData["Title"]     = Model.CourseNumber;
    ViewData["PageTitle"] = "COURSES";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var bookItems    = Model.Items.Where(i => i.ItemType == ItemType.Book).ToList();
    var supplyItems  = Model.Items.Where(i => i.ItemType == ItemType.Supply).ToList();
    var msgCount     = 0; // placeholder for messages count
}

@section SubHeaderActions {
  <a class="btn-back-courses" asp-controller="Dashboard" asp-action="Index">
    ← BACK TO COURSES
  </a>
  <button class="btn-next-course" disabled>NEXT COURSE →</button>
  <a class="btn-watch-video" href="#">
    <i class="bi bi-play-circle-fill me-1"></i>WATCH VIDEO
  </a>
  <div class="dropdown">
    <button class="btn-course-actions dropdown-toggle" type="button" data-bs-toggle="dropdown">
      COURSE ACTIONS
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
      <!-- ADD SECTION -->
      <li>
        <button class="dropdown-item" type="button"
                data-bs-toggle="modal" data-bs-target="#addSectionModal">
          <i class="bi bi-plus-circle me-2"></i>Add Section
        </button>
      </li>
      <li><hr class="dropdown-divider"></li>
      @if (role == "OfficeManager" && Model.Status == RequestStatus.PendingVerification)
      {
        <li>
          <a class="dropdown-item" asp-controller="Requests" asp-action="Verify" asp-route-id="@Model.Id">
            <i class="bi bi-shield-check me-2"></i>Verify this Request
          </a>
        </li>
      }
      @if (role == "BookstoreStaff" && Model.Status == RequestStatus.Verified)
      {
        <li>
          <a class="dropdown-item text-success" asp-controller="Requests" asp-action="Approve" asp-route-id="@Model.Id">
            <i class="bi bi-check-circle me-2"></i>Approve this Request
          </a>
        </li>
      }
      <li>
        <a class="dropdown-item" asp-controller="Availability" asp-action="Index">
          <i class="bi bi-robot me-2"></i>Book Availability Report
        </a>
      </li>
      <li>
        <a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
          <i class="bi bi-arrow-left me-2"></i>Back to Courses
        </a>
      </li>
    </ul>
  </div>
}

<!-- ═══ Detail Layout ═══ -->
<div class="verba-detail-layout">

  <!-- Left Sidebar: Sections list -->
  <aside class="verba-detail-sidebar">
    <button class="detail-sidebar-merge-btn">
      <i class="bi bi-diagram-2 me-1"></i>MERGE OR SPLIT SECTIONS
    </button>

    <!-- Section entry -->
    <div class="detail-section-item active">
      <span class="detail-section-dots">● ● ●</span>
      <div>
        <div>@(Model.Submitter?.FullName?.ToUpper() ?? "UNKNOWN")</div>
        <div style="font-size:9px;color:#667;font-weight:400;">(@(Model.Section ?? "01"))</div>
      </div>
    </div>

    <!-- If multiple items, show them as sub-sections -->
    @if (bookItems.Count > 1)
    {
      @for (int i = 0; i < bookItems.Count; i++)
      {
        <div class="detail-section-item" style="padding-left:24px;">
          <i class="bi bi-pencil detail-section-pencil"></i>
          <div style="font-size:10px;">@bookItems[i].Title?.ToUpper()</div>
        </div>
      }
    }

    <!-- Spacer / gray area -->
    <div style="flex:1; background:#e8eaed; min-height:200px; margin-top:8px;"></div>
  </aside>

  <!-- Main Content -->
  <div class="verba-detail-main">

    <!-- Message bar + Approved button -->
    <div class="detail-message-bar">
      <input class="detail-message-input" type="text" placeholder="Post or send a message..." />
      <div style="display:flex;">
        <button class="btn-approved-green">
          @if (Model.Status == RequestStatus.Approved)
          {
            <i class="bi bi-check-lg me-1"></i>
            <text>APPROVED</text>
          }
          else if (Model.Status == RequestStatus.Verified)
          {
            <i class="bi bi-shield-check me-1"></i>
            <text>REVIEWED</text>
          }
          else
          {
            <i class="bi bi-hourglass-split me-1"></i>
            <text>PENDING</text>
          }
        </button>
        <button class="btn-approved-refresh"><i class="bi bi-arrow-clockwise"></i></button>
      </div>
    </div>

    <!-- Tabs -->
    <div class="detail-tabs">
      <button class="detail-tab active" onclick="switchTab(this,'tab-materials')">
        <span class="detail-tab-count">@Model.Items.Count</span>
        SELECTED MATERIALS
      </button>
      <button class="detail-tab" onclick="switchTab(this,'tab-copy')">
        COPY ANOTHER ADOPTION
      </button>
      <button class="detail-tab" onclick="switchTab(this,'tab-add')">
        ADD MATERIALS
      </button>
      <button class="detail-tab" onclick="switchTab(this,'tab-messages')">
        <span class="detail-tab-count" style="background:#556;">@msgCount</span>
        MESSAGES &amp; ACTIVITY
      </button>
    </div>

    <!-- Tab Content -->
    <div class="detail-tab-content">

      <!-- Tab: Selected Materials -->
      <div id="tab-materials" class="detail-tab-pane active" style="padding:0;">
        @if (!Model.Items.Any())
        {
          <div class="no-materials-state">
            <div class="no-materials-icon">⚠</div>
            <div class="no-materials-text">
              @if (Model.Status == RequestStatus.Approved)
              {
                <text>APPROVED WITH NO TEXT REQUIRED</text>
              }
              else
              {
                <text>NO MATERIALS SUBMITTED YET</text>
              }
            </div>
          </div>
        }
        else
        {
          @foreach (var item in Model.Items)
          {
            var hasIsbn  = !string.IsNullOrEmpty(item.Isbn);
            var hasTitle = !string.IsNullOrEmpty(item.Title);

            <div class="material-list-item">

              <!-- Green check strip -->
              <div class="mat-check-strip">
                <i class="bi bi-check-lg"></i>
              </div>

              <!-- Book thumbnail -->
              <div class="mat-book-thumb">
                <div class="mat-thumb-placeholder"></div>
              </div>

              <!-- Book details -->
              <div class="mat-details-col">
                <div class="mat-book-title">@(item.Title?.ToUpper() ?? "UNTITLED")</div>
                @if (!string.IsNullOrEmpty(item.Author))
                {
                  <div class="mat-book-meta-line">@item.Author.ToUpper()</div>
                }
                <div class="mat-book-meta-line">
                  ADOPTED ISBN: @(hasIsbn ? item.Isbn : "")
                </div>
                @if (hasIsbn)
                {
                  <div class="mat-book-meta-line">PRINT ISBN-13: @item.Isbn</div>
                  <div class="mat-book-meta-line">PRINT ISBN-10: @item.Isbn</div>
                }
                <div class="mat-book-meta-line">
                  PUBLISHER: @(string.IsNullOrEmpty(item.Publisher) ? "N/A" : item.Publisher.ToUpper())
                </div>
                @if (!string.IsNullOrEmpty(item.Edition))
                {
                  <div class="mat-book-meta-line">EDITION: @item.Edition.ToUpper()</div>
                }
                @if (item.PublicationYear.HasValue)
                {
                  <div class="mat-book-meta-line">PUBLICATION DATE: JANUARY 01, @item.PublicationYear</div>
                }
                <div id="mat-price-@item.Id" class="mat-book-meta-line" style="display:none;"></div>
                <div style="display:flex; flex-direction:column; gap:3px; margin-top:5px;">
                  <a class="mat-view-link"
                     href="@(string.IsNullOrEmpty(item.Isbn) ? "#" : Url.Action("Item","Availability",new{isbn=item.Isbn}))">
                    <i class="bi bi-box-arrow-up-right"></i> VIEW ON ITEMS PAGE
                  </a>
                  @if (item.ItemType == ItemType.Book)
                  {
                    <a class="mat-accessibility-link" href="#">
                      <i class="bi bi-eye"></i> ACCESSIBILITY CLAIMS FOR DIGITAL VERSION
                    </a>
                  }
                </div>
              </div>

              <!-- Right action panel -->
              <div class="mat-actions-col">
                <form method="post" asp-action="RemoveItem" asp-route-id="@Model.Id"
                      style="display:inline;margin:0;"
                      onsubmit="return confirm('Remove \'@(item.Title?.Replace("'","") ?? "this item")\' from the list? This cannot be undone.')">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="itemId" value="@item.Id" />
                  <button type="submit" class="btn-mat-remove">✕ REMOVE FROM LIST</button>
                </form>

                <div class="mat-required-row">
                  <select class="mat-required-select">
                    @if (item.IsRequired)
                    {
                      <option selected>REQUIRED</option>
                      <option>OPTIONAL</option>
                    }
                    else
                    {
                      <option>REQUIRED</option>
                      <option selected>OPTIONAL</option>
                    }
                    <option>RECOMMENDED</option>
                  </select>
                  <span class="mat-required-arrow">&#x25B2;</span>
                </div>

                <button class="btn-mat-accordion">
                  <i class="bi bi-caret-right-fill"></i> ITEM QUESTIONS
                </button>

                <button class="btn-mat-accordion">
                  <i class="bi bi-caret-down-fill"></i> AUTO ACCESS
                </button>

                <div class="mat-ia-flags-row">
                  <div class="mat-ia-flag" data-isbn="@item.Isbn" data-item-id="@item.Id">
                    <i class="bi bi-question-circle"></i>
                    <span>DIGITAL MATCH</span>
                  </div>
                  <div class="mat-ia-flag" data-isbn-price="@item.Isbn">
                    <i class="bi bi-question-circle"></i>
                    <span>HAS IA PRICE</span>
                  </div>
                </div>

                <div class="mat-ia-interest-row">
                  <button class="btn-mat-no-ia">⊘ NO IA INTEREST</button>
                  <button class="btn-mat-edit-split">
                    <i class="bi bi-pencil"></i> ▾
                  </button>
                </div>

                <button class="btn-mat-message-users">
                  <i class="bi bi-envelope-fill"></i> MESSAGE USERS
                </button>
              </div>

            </div><!-- /material-list-item -->
          }
        }
      </div>

      <!-- Tab: Copy Another Adoption -->
      <div id="tab-copy" class="detail-tab-pane">
        @{
          var prevAdoptions = ViewBag.PreviousAdoptions as List<BYUIVerbaCollect.Models.CourseRequest>
                              ?? new List<BYUIVerbaCollect.Models.CourseRequest>();
        }
        @if (!prevAdoptions.Any())
        {
          <div class="no-materials-state">
            <div class="no-materials-icon"><i class="bi bi-files"></i></div>
            <div class="no-materials-text">NO PREVIOUS ADOPTIONS FOUND FOR @Model.CourseNumber</div>
          </div>
        }
        else
        {
          <div style="padding:16px;">
            <div style="font-size:10px;font-weight:700;color:#556;letter-spacing:.6px;margin-bottom:14px;text-transform:uppercase;">
              <i class="bi bi-clock-history me-1"></i>PREVIOUS SEMESTER MATERIALS — @Model.CourseNumber
              <span style="font-weight:400;color:#889;margin-left:6px;">Click a book to add it to this request</span>
            </div>

            @foreach (var prev in prevAdoptions)
            {
              var prevBooks = prev.Items.Where(i => i.ItemType == ItemType.Book).ToList();
              <div style="border:1px solid #dde;border-radius:4px;margin-bottom:14px;overflow:hidden;">

                <!-- Adoption header -->
                <div style="background:#f0f2f5;padding:10px 14px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #dde;">
                  <div>
                    <span style="font-size:12px;font-weight:700;color:#334;">@prev.Semester</span>
                    @if (!string.IsNullOrEmpty(prev.Section))
                    { <span style="font-size:10px;color:#667;margin-left:6px;">Section @prev.Section</span> }
                    <span style="font-size:10px;color:#889;margin-left:8px;">by @(prev.Submitter?.FullName ?? "Unknown")</span>
                    <span style="font-size:10px;color:#aab;margin-left:6px;">— @prev.Items.Count material(s)</span>
                  </div>
                  <span style="font-size:10px;
                    padding:2px 8px;border-radius:10px;font-weight:700;
                    background:@(prev.Status == RequestStatus.Approved ? "#d4edda" : prev.Status == RequestStatus.Verified ? "#cce5ff" : "#fff3cd");
                    color:@(prev.Status == RequestStatus.Approved ? "#155724" : prev.Status == RequestStatus.Verified ? "#004085" : "#856404");">
                    @prev.Status
                  </span>
                </div>

                <!-- Book rows -->
                @foreach (var pi in prev.Items.Where(i => i.ItemType == ItemType.Book))
                {
                  <div style="padding:10px 14px;border-bottom:1px solid #eef;display:flex;align-items:center;gap:12px;">
                    <div style="flex:1;">
                      <div style="font-size:12px;font-weight:700;color:#334;">@(pi.Title?.ToUpper() ?? "UNTITLED")</div>
                      @if (!string.IsNullOrEmpty(pi.Author))
                      { <div style="font-size:10px;color:#667;">@pi.Author</div> }
                      @if (!string.IsNullOrEmpty(pi.Isbn))
                      { <code style="font-size:10px;color:#889;">ISBN: @pi.Isbn</code> }
                    </div>
                    <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
                      @if (pi.IsRequired)
                      { <span style="background:#dc3545;color:#fff;font-size:9px;padding:1px 6px;border-radius:10px;font-weight:700;">REQUIRED</span> }
                      else
                      { <span style="background:#6c757d;color:#fff;font-size:9px;padding:1px 6px;border-radius:10px;font-weight:700;">OPTIONAL</span> }
                      @if (!string.IsNullOrEmpty(pi.Isbn))
                      {
                        <form method="post" asp-action="AddItem" asp-route-id="@Model.Id" style="margin:0;">
                          @Html.AntiForgeryToken()
                          <input type="hidden" name="isbn"      value="@pi.Isbn" />
                          <input type="hidden" name="title"     value="@pi.Title" />
                          <input type="hidden" name="author"    value="@pi.Author" />
                          <input type="hidden" name="publisher" value="@pi.Publisher" />
                          <input type="hidden" name="edition"   value="@pi.Edition" />
                          <input type="hidden" name="publicationYear" value="@pi.PublicationYear" />
                          <input type="hidden" name="isRequired" value="@pi.IsRequired.ToString().ToLower()" />
                          <button type="submit"
                                  style="background:#003B71;color:#fff;border:none;border-radius:3px;
                                         padding:4px 10px;font-size:10px;font-weight:700;cursor:pointer;">
                            <i class="bi bi-plus-circle me-1"></i>ADD TO THIS REQUEST
                          </button>
                        </form>
                      }
                    </div>
                  </div>
                }

                @if (!prevBooks.Any())
                {
                  <div style="padding:10px 14px;font-size:11px;color:#aab;font-style:italic;">No books in this adoption.</div>
                }
              </div>
            }
          </div>
        }
      </div>

      <!-- Tab: Add Materials -->
      <div id="tab-add" class="detail-tab-pane">
        <div class="add-material-form">

          <!-- ISBN lookup row -->
          <div class="add-isbn-row">
            <input id="addIsbn" class="add-isbn-input" type="text"
                   placeholder="Enter ISBN (10 or 13 digits)..."
                   onkeydown="if(event.key==='Enter'){event.preventDefault();lookupAddIsbn();}" />
            <button class="btn-add-lookup" type="button" onclick="lookupAddIsbn()">
              <i class="bi bi-upc-scan"></i> LOOK UP ISBN
            </button>
          </div>

          <!-- Divider -->
          <div class="add-search-divider">OR SEARCH BY TITLE</div>

          <!-- Title search row -->
          <div class="add-title-row">
            <input id="addTitleInput" class="add-title-input" type="text"
                   placeholder="Book title..."
                   onkeydown="if(event.key==='Enter'){event.preventDefault();searchByTitle();}" />
            <button class="btn-add-lookup" type="button" onclick="searchByTitle()">
              <i class="bi bi-search"></i> SEARCH
            </button>
          </div>

          <!-- Title search results -->
          <div id="searchResultsList" class="search-results-list" style="display:none;"></div>

          <!-- Preview card (shown after a successful lookup) -->
          <div id="addPreviewCard" class="add-preview-card" style="display:none;">

            <!-- Book thumbnail + metadata -->
            <div class="add-preview-main">
              <div class="add-preview-img">
                <div class="mat-thumb-placeholder" id="addThumbPlaceholder"></div>
              </div>
              <div class="add-preview-details">
                <div class="add-preview-title" id="addPreviewTitle">—</div>
                <div class="add-preview-meta"  id="addPreviewMeta"></div>
                <div class="add-preview-isbn"  id="addPreviewIsbnDisplay"></div>
              </div>
            </div>

            <!-- Availability check panel -->
            <div class="add-availability-section">
              <button class="btn-check-avail" type="button" id="btnCheckAvail" onclick="checkAvailability()">
                <i class="bi bi-search"></i> CHECK DIGITAL &amp; PRICE AVAILABILITY
              </button>
              <div id="availResults" class="avail-results" style="display:none;"></div>
            </div>

            <!-- Add-to-list form -->
            <form method="post" asp-action="AddItem" asp-route-id="@Model.Id">
              @Html.AntiForgeryToken()
              <input type="hidden" id="hidIsbn"      name="isbn" />
              <input type="hidden" id="hidTitle"     name="title" />
              <input type="hidden" id="hidAuthor"    name="author" />
              <input type="hidden" id="hidPublisher" name="publisher" />
              <input type="hidden" id="hidEdition"   name="edition" />
              <input type="hidden" id="hidYear"      name="publicationYear" />
              <div class="add-form-row">
                <label class="add-req-label">
                  <input type="checkbox" name="isRequired" value="true" checked /> REQUIRED
                </label>
                <button class="btn-add-to-list" type="submit">
                  <i class="bi bi-plus-circle-fill"></i> ADD TO MATERIALS LIST
                </button>
              </div>
            </form>

          </div><!-- /addPreviewCard -->
        </div><!-- /add-material-form -->
      </div>

      <!-- Tab: Messages & Activity -->
      <div id="tab-messages" class="detail-tab-pane">
        <div class="small text-muted mb-3">Activity log for request #@Model.Id</div>
        <div class="material-card">
          <div class="d-flex gap-2 align-items-start">
            <i class="bi bi-clock-history text-muted"></i>
            <div>
              <div class="fw-bold" style="font-size:12px;">Request Submitted</div>
              <div style="font-size:11px;color:#778;">@Model.SubmittedAt.ToString("MMM d, yyyy h:mm tt") by @Model.Submitter?.FullName</div>
            </div>
          </div>
        </div>
        @if (Model.VerifiedAt.HasValue)
        {
          <div class="material-card">
            <div class="d-flex gap-2 align-items-start">
              <i class="bi bi-shield-check text-info"></i>
              <div>
                <div class="fw-bold" style="font-size:12px;">Request Verified</div>
                <div style="font-size:11px;color:#778;">@Model.VerifiedAt.Value.ToString("MMM d, yyyy h:mm tt") by @Model.VerifiedBy?.FullName</div>
              </div>
            </div>
          </div>
        }
        @if (Model.ApprovedAt.HasValue)
        {
          <div class="material-card">
            <div class="d-flex gap-2 align-items-start">
              <i class="bi bi-check-circle text-success"></i>
              <div>
                <div class="fw-bold" style="font-size:12px;">Request Approved</div>
                <div style="font-size:11px;color:#778;">@Model.ApprovedAt.Value.ToString("MMM d, yyyy h:mm tt") by @Model.ApprovedBy?.FullName</div>
              </div>
            </div>
          </div>
        }
      </div>

    </div><!-- /tab-content -->
  </div><!-- /detail-main -->
</div><!-- /detail-layout -->

<!-- ═══ Add Section Modal ═══ -->
<div class="modal fade" id="addSectionModal" tabindex="-1" aria-labelledby="addSectionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius:4px; overflow:hidden;">

      <!-- Modal header -->
      <div class="modal-header" style="background:var(--verba-dark2); color:#fff; border:none; padding:14px 20px;">
        <h5 class="modal-title" id="addSectionModalLabel" style="font-size:14px; font-weight:800; letter-spacing:.5px; text-transform:uppercase;">
          <i class="bi bi-plus-circle me-2"></i>Add New Section — @Model.CourseNumber
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <!-- Modal body -->
      <form method="post" asp-action="AddSection" asp-route-id="@Model.Id">
        @Html.AntiForgeryToken()
        <div class="modal-body" style="padding:24px; background:#f7f8fb;">

          <!-- Info banner -->
          <div style="background:#e8f0fe; border:1px solid #c5d6f8; border-radius:4px; padding:10px 14px; margin-bottom:18px; font-size:12px; color:#1a56db;">
            <i class="bi bi-info-circle me-1"></i>
            This will create a new course section that shares the same course materials as <strong>@Model.CourseNumber — @(Model.CourseName ?? Model.CourseNumber)</strong>.
          </div>

          <div class="row g-3">
            <!-- Section Number -->
            <div class="col-md-4">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                SECTION NUMBER <span class="text-danger">*</span>
              </label>
              <input type="text" class="form-control form-control-sm" name="section"
                     placeholder="e.g. A2, B1, OL1"
                     style="border-color:#ccd; font-size:12px;" required />
            </div>

            <!-- Semester -->
            <div class="col-md-4">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                SEMESTER
              </label>
              <input type="text" class="form-control form-control-sm" name="semester"
                     value="@Model.Semester" placeholder="e.g. SPRING 2026"
                     style="border-color:#ccd; font-size:12px;" />
            </div>

            <!-- Instructor Name -->
            <div class="col-md-4">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                INSTRUCTOR
              </label>
              <input type="text" class="form-control form-control-sm" name="instructorName"
                     placeholder="Last, First"
                     style="border-color:#ccd; font-size:12px;" />
            </div>

            <!-- Course Name (pre-filled, editable) -->
            <div class="col-md-6">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                COURSE NAME
              </label>
              <input type="text" class="form-control form-control-sm" name="courseName"
                     value="@Model.CourseName" placeholder="Course full name"
                     style="border-color:#ccd; font-size:12px;" />
            </div>

            <!-- Course Number (pre-filled, read-only) -->
            <div class="col-md-3">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                COURSE NUMBER
              </label>
              <input type="text" class="form-control form-control-sm" name="courseNumber"
                     value="@Model.CourseNumber" readonly
                     style="background:#e8eaef; border-color:#ccd; font-size:12px;" />
            </div>

            <!-- Copy materials checkbox -->
            <div class="col-md-3 d-flex align-items-end">
              <div class="form-check mb-1">
                <input class="form-check-input" type="checkbox" name="copyMaterials" value="true" id="chkCopyMaterials" checked />
                <label class="form-check-label" for="chkCopyMaterials"
                       style="font-size:11px; font-weight:700; color:#334;">
                  Copy materials from this section
                </label>
              </div>
            </div>

            <!-- Notes -->
            <div class="col-12">
              <label class="form-label" style="font-size:10px; font-weight:700; letter-spacing:.8px; color:#556; text-transform:uppercase;">
                NOTES (OPTIONAL)
              </label>
              <textarea class="form-control form-control-sm" name="notes" rows="2"
                        placeholder="Any notes about this section..."
                        style="border-color:#ccd; font-size:12px; resize:none;"></textarea>
            </div>

            <!-- ══════════════════════════════════════════════════════════
                 NEW COURSE MATERIALS  (brand-new — not copied from source)
                 ══════════════════════════════════════════════════════════ -->
            <div class="col-12 mt-3">
              <div style="border-top:2px dashed #b0b8cc; padding-top:14px;">

                <!-- Section header + Add buttons -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <div>
                    <span style="font-size:10px;font-weight:800;letter-spacing:.8px;color:#334;text-transform:uppercase;">
                      <i class="bi bi-stars me-1" style="color:#f59e0b;"></i>NEW COURSE MATERIALS
                    </span>
                    <span style="font-size:9px;color:#889;margin-left:6px;">
                      (books &amp; supplies nobody has registered before)
                    </span>
                  </div>
                  <div class="d-flex gap-2">
                    <button type="button" onclick="secAddBook()"
                            style="background:#003B71;color:#fff;border:none;border-radius:3px;
                                   padding:4px 11px;font-size:10px;font-weight:700;letter-spacing:.4px;cursor:pointer;">
                      <i class="bi bi-book me-1"></i>ADD BOOK
                    </button>
                    <button type="button" onclick="secAddSupply()"
                            style="background:#445566;color:#fff;border:none;border-radius:3px;
                                   padding:4px 11px;font-size:10px;font-weight:700;letter-spacing:.4px;cursor:pointer;">
                      <i class="bi bi-box-seam me-1"></i>ADD SUPPLY
                    </button>
                  </div>
                </div>

                <!-- Dynamic rows land here -->
                <div id="secItemsContainer"></div>

                <!-- Empty-state hint -->
                <div id="secEmptyMsg"
                     style="text-align:center;color:#99a;font-size:11px;padding:8px 0 4px;">
                  <i class="bi bi-inbox me-1"></i>
                  No new materials yet — click <strong>ADD BOOK</strong> or <strong>ADD SUPPLY</strong> above.
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Modal footer -->
        <div class="modal-footer" style="background:#fff; border-top:1px solid var(--verba-border); padding:12px 20px;">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal"
                  style="font-size:11px; font-weight:700; letter-spacing:.4px;">
            CANCEL
          </button>
          <button type="submit" class="btn btn-sm"
                  style="background:var(--verba-green); color:#fff; font-size:11px; font-weight:700; letter-spacing:.5px; border:none; padding:6px 18px;">
            <i class="bi bi-plus-circle-fill me-1"></i>ADD SECTION
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
// ── Tab switching ──────────────────────────────────────────────
function switchTab(btn, tabId) {
  document.querySelectorAll('.detail-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.detail-tab-pane').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(tabId).classList.add('active');
}

// ── ISBN lookup ────────────────────────────────────────────────
async function lookupAddIsbn() {
  const isbn = document.getElementById('addIsbn').value.trim();
  if (!isbn) return;
  const btn = document.querySelector('.add-isbn-row .btn-add-lookup');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass-split"></i> LOOKING UP...';
  try {
    const resp = await fetch('/api/isbn-direct?isbn=' + encodeURIComponent(isbn));
    if (!resp.ok) {
      alert('Book not found for ISBN: ' + isbn + '. Try searching by title instead.');
      return;
    }
    const book = await resp.json();
    fillPreview(book, isbn);
    document.getElementById('searchResultsList').style.display = 'none';
  } catch(e) {
    alert('Lookup error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-upc-scan"></i> LOOK UP ISBN';
  }
}

// ── Title search ───────────────────────────────────────────────
async function searchByTitle() {
  const title = document.getElementById('addTitleInput').value.trim();
  if (!title) return;
  const btn = document.querySelector('.add-title-row .btn-add-lookup');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass-split"></i> SEARCHING...';
  try {
    const resp = await fetch('/api/isbn-search?title=' + encodeURIComponent(title));
    if (!resp.ok) throw new Error('Search failed');
    const books = await resp.json();
    showSearchResults(books);
  } catch(e) {
    alert('Search error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-search"></i> SEARCH';
  }
}

function showSearchResults(books) {
  const list = document.getElementById('searchResultsList');
  if (!books || books.length === 0) {
    list.innerHTML = '<div style="padding:14px;text-align:center;color:#889;font-size:12px;">No results found. Try a different title.</div>';
    list.style.display = 'block';
    return;
  }
  list.innerHTML = books.map(b => {
    const meta = [b.author, b.publisher, b.edition].filter(Boolean).join(' · ');
    const safeB = JSON.stringify(b).replace(/'/g, "\\'");
    return `<div class="search-result-item" onclick='selectSearchResult(${safeB.replace(/"/g,"&quot;")})'>
      <div>
        <div class="search-result-title">${escHtml(b.title || 'Unknown')}</div>
        ${meta ? `<div class="search-result-meta">${escHtml(meta)}</div>` : ''}
        ${b.isbn ? `<div class="search-result-isbn">ISBN: ${escHtml(b.isbn)}</div>` : ''}
      </div>
    </div>`;
  }).join('');
  list.style.display = 'block';
}

function selectSearchResult(book) {
  document.getElementById('addIsbn').value = book.isbn || '';
  document.getElementById('searchResultsList').style.display = 'none';
  fillPreview(book, book.isbn || '');
}

// ── Fill preview card ──────────────────────────────────────────
function fillPreview(book, isbn) {
  // Hidden form fields
  document.getElementById('hidIsbn').value      = isbn;
  document.getElementById('hidTitle').value     = book.title     || '';
  document.getElementById('hidAuthor').value    = book.author    || '';
  document.getElementById('hidPublisher').value = book.publisher || '';
  document.getElementById('hidEdition').value   = book.edition   || '';
  document.getElementById('hidYear').value      = book.year      || book.publicationYear || '';

  // Display
  document.getElementById('addPreviewTitle').textContent = (book.title || 'Unknown Title').toUpperCase();
  const meta = [book.author, book.publisher, book.edition, book.year || book.publicationYear]
    .filter(Boolean).join(' · ');
  document.getElementById('addPreviewMeta').textContent  = meta;
  document.getElementById('addPreviewIsbnDisplay').textContent = isbn ? 'ISBN: ' + isbn : '';

  // Reset availability panel
  document.getElementById('availResults').style.display = 'none';
  document.getElementById('btnCheckAvail').innerHTML = '<i class="bi bi-search"></i> CHECK DIGITAL &amp; PRICE AVAILABILITY';
  document.getElementById('btnCheckAvail').disabled = false;

  document.getElementById('addPreviewCard').style.display = 'block';
}

// ── Availability check ─────────────────────────────────────────
async function checkAvailability() {
  const isbn = document.getElementById('hidIsbn').value.trim();
  if (!isbn) { alert('Please look up a book first.'); return; }

  const btn = document.getElementById('btnCheckAvail');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass-split"></i> CHECKING...';

  try {
    const resp = await fetch('/api/check-availability?isbn=' + encodeURIComponent(isbn));
    if (!resp.ok) throw new Error('Failed');
    const data = await resp.json();
    renderAvailResults(data);
  } catch(e) {
    document.getElementById('availResults').innerHTML =
      '<span class="avail-error"><i class="bi bi-exclamation-triangle me-1"></i>Could not check availability. Try again later.</span>';
    document.getElementById('availResults').style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> RE-CHECK AVAILABILITY';
  }
}

function renderAvailResults(data) {
  const chk = '<i class="bi bi-check-circle-fill" style="color:#2e7d32;font-size:20px;"></i>';
  const qst = '<i class="bi bi-question-circle" style="color:#778;font-size:20px;"></i>';

  let html = '<div class="avail-grid">';

  // Digital match (VitalSource)
  html += `<div class="avail-item">
    ${data.digitalVitalSource ? chk : qst}
    <div class="avail-item-label">DIGITAL MATCH</div>
    <a class="avail-link" href="${data.vitalsourceUrl}" target="_blank">View on VitalSource ↗</a>
  </div>`;

  // Has IA price (Google / Amazon)
  const hasPrice = data.digitalGoogle || data.printPrice || data.googlePrice;
  const priceVal = data.printPrice || data.googlePrice;
  html += `<div class="avail-item">
    ${hasPrice ? chk : qst}
    <div class="avail-item-label">HAS IA PRICE</div>
    ${priceVal ? `<span class="avail-price">$${parseFloat(priceVal).toFixed(2)}</span>` : ''}
    <a class="avail-link" href="${data.amazonUrl}" target="_blank">Check Amazon ↗</a>
  </div>`;

  html += '</div>';

  // External links row
  html += '<div class="avail-links-row">';
  html += `<a class="avail-ext-link" href="${data.vitalsourceUrl}" target="_blank"><i class="bi bi-box-arrow-up-right"></i> VITALSOURCE</a>`;
  html += `<a class="avail-ext-link" href="${data.amazonUrl}" target="_blank"><i class="bi bi-box-arrow-up-right"></i> AMAZON</a>`;
  if (data.googleBuyLink) {
    html += `<a class="avail-ext-link" href="${data.googleBuyLink}" target="_blank"><i class="bi bi-box-arrow-up-right"></i> GOOGLE BOOKS</a>`;
  }
  html += '</div>';

  const el = document.getElementById('availResults');
  el.innerHTML = html;
  el.style.display = 'block';
}

// ── HTML escape helper ─────────────────────────────────────────
function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ════════════════════════════════════════════════════════════════
//  NEW COURSE MATERIALS  (inside Add Section modal)
//  All functions prefixed with "sec" to avoid naming collisions.
//  Form fields: NewItems[idx].FieldName  → binds to List<ItemViewModel> NewItems
// ════════════════════════════════════════════════════════════════
let secItemCount = 0;

// ── Add Book row ──────────────────────────────────────────────
function secAddBook() {
  const idx = secItemCount++;
  document.getElementById('secEmptyMsg').style.display = 'none';

  const div = document.createElement('div');
  div.id = `secItem_${idx}`;
  div.style.cssText = 'background:#fff;border:1px solid #dde;border-radius:4px;padding:12px;margin-bottom:10px;';
  div.innerHTML = `
    <input type="hidden" name="NewItems[${idx}].ItemType" value="Book"/>

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
      <span style="background:#003B71;color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:3px;letter-spacing:.4px;">
        <i class="bi bi-book me-1"></i>NEW BOOK #${idx + 1}
      </span>
      <button type="button" onclick="secRemoveItem('secItem_${idx}')"
              style="background:none;border:1px solid #e55;color:#e55;border-radius:3px;padding:2px 8px;font-size:10px;cursor:pointer;">
        <i class="bi bi-trash"></i> REMOVE
      </button>
    </div>

    <!-- ISBN lookup bar -->
    <div id="secIsbnBar_${idx}" style="background:#f0fff4;border:1px solid #b7dfbf;border-radius:4px;padding:10px;margin-bottom:8px;">
      <div style="font-size:10px;font-weight:700;color:#1a7340;margin-bottom:6px;">
        <i class="bi bi-upc-scan me-1"></i>ENTER ISBN TO AUTO-FILL
        <span style="background:#1a7340;color:#fff;font-size:9px;padding:1px 5px;border-radius:3px;margin-left:4px;">RECOMMENDED</span>
      </div>
      <div style="display:flex;gap:6px;">
        <input type="text" id="secIsbnInput_${idx}" class="form-control form-control-sm font-monospace"
               placeholder="e.g. 9780134190440"
               oninput="secClearConfirmation(${idx})"
               onkeydown="if(event.key==='Enter'){event.preventDefault();secLookupByIsbn(${idx});}"
               style="flex:1;font-size:12px;" />
        <button type="button" onclick="secLookupByIsbn(${idx})"
                style="background:#1a7340;color:#fff;border:none;border-radius:3px;padding:4px 10px;font-size:10px;font-weight:700;white-space:nowrap;cursor:pointer;">
          <i class="bi bi-search me-1"></i>LOOK UP
        </button>
      </div>
      <div id="secIsbnSpinner_${idx}" class="d-none mt-1" style="font-size:11px;color:#556;">
        <i class="bi bi-hourglass-split me-1"></i>Looking up…
      </div>
      <div id="secIsbnError_${idx}" class="d-none mt-1" style="font-size:11px;color:#c00;"></div>

      <!-- Confirmation panel -->
      <div id="secConfirmPanel_${idx}" class="d-none mt-2">
        <div style="border:1px solid #1a7340;border-radius:4px;overflow:hidden;">
          <div style="background:#1a7340;color:#fff;padding:6px 10px;font-size:10px;font-weight:700;">
            <i class="bi bi-check-circle me-1"></i>BOOK FOUND — PLEASE CONFIRM
            <span id="secCacheTag_${idx}" class="d-none" style="background:#f59e0b;color:#1a1a1a;font-size:9px;padding:1px 5px;border-radius:3px;margin-left:6px;">
              <i class="bi bi-database me-1"></i>FROM LOCAL CATALOG
            </span>
          </div>
          <div style="padding:8px 10px;background:#f6fff8;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;font-size:11px;">
              <div><span style="color:#667;">Title:</span> <strong id="secConfTitle_${idx}"></strong></div>
              <div><span style="color:#667;">Author:</span> <span id="secConfAuthor_${idx}"></span></div>
              <div><span style="color:#667;">ISBN:</span> <code id="secConfIsbn_${idx}" style="color:#1a7340;font-weight:700;"></code></div>
              <div><span style="color:#667;">Publisher:</span> <span id="secConfPublisher_${idx}"></span></div>
              <div><span style="color:#667;">Edition:</span> <span id="secConfEdition_${idx}"></span></div>
              <div><span style="color:#667;">Year:</span> <span id="secConfYear_${idx}"></span></div>
              <!-- License fee row — shown only when VitalSource returns a price -->
              <div id="secConfLicenseFeeWrap_${idx}" class="d-none"
                   style="grid-column:1/-1;margin-top:4px;padding:5px 8px;
                          background:#e3f2fd;border:1px solid #90caf9;border-radius:4px;
                          display:flex;align-items:center;gap:8px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                     fill="none" stroke="#1565c0" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span style="font-size:10px;font-weight:800;color:#1565c0;letter-spacing:.04em;">DIGITAL</span>
                <span style="font-size:10px;color:#556;">eTextbook License Fee:</span>
                <strong id="secConfLicenseFeeText_${idx}" style="color:#1565c0;font-size:12px;"></strong>
              </div>
            </div>
          </div>
          <div style="padding:6px 10px;background:#eaf7ed;display:flex;gap:6px;">
            <button type="button" onclick="secConfirmBook(${idx})"
                    style="background:#1a7340;color:#fff;border:none;border-radius:3px;padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;">
              <i class="bi bi-check-lg me-1"></i>CONFIRM &amp; USE
            </button>
            <button type="button" onclick="secClearConfirmation(${idx})"
                    style="background:none;border:1px solid #aaa;border-radius:3px;padding:4px 10px;font-size:10px;cursor:pointer;">
              CANCEL
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Confirmed summary (shown after confirmation) -->
    <div id="secBookFields_${idx}" class="d-none">
      <div style="background:#eaf7ed;border:1px solid #b7dfbf;border-radius:4px;padding:8px 12px;
                  font-size:11px;display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
        <span>
          <i class="bi bi-check-circle-fill text-success me-1"></i>
          <strong id="secConfirmedTitle_${idx}"></strong> —
          ISBN <code id="secConfirmedIsbn_${idx}" style="color:#1a7340;font-weight:700;"></code>
        </span>
        <button type="button" onclick="secResetBook(${idx})"
                style="background:none;border:1px solid #aaa;border-radius:3px;padding:2px 8px;font-size:10px;cursor:pointer;">
          <i class="bi bi-arrow-counterclockwise me-1"></i>CHANGE
        </button>
      </div>
      <input type="hidden" name="NewItems[${idx}].Title"           id="secH_title_${idx}" />
      <input type="hidden" name="NewItems[${idx}].Author"          id="secH_author_${idx}" />
      <input type="hidden" name="NewItems[${idx}].Isbn"            id="secH_isbn_${idx}" />
      <input type="hidden" name="NewItems[${idx}].Publisher"       id="secH_publisher_${idx}" />
      <input type="hidden" name="NewItems[${idx}].Edition"         id="secH_edition_${idx}" />
      <input type="hidden" name="NewItems[${idx}].PublicationYear" id="secH_year_${idx}" />
    </div>

    <!-- Quantity / Required / Notes -->
    <div style="display:grid;grid-template-columns:80px 1fr 2fr;gap:8px;align-items:end;">
      <div>
        <label style="font-size:10px;color:#556;font-weight:700;">QTY</label>
        <input type="number" name="NewItems[${idx}].Quantity" value="1" min="1" max="999"
               class="form-control form-control-sm" style="font-size:12px;" />
      </div>
      <div style="padding-bottom:4px;">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="NewItems[${idx}].IsRequired"
                 value="true" checked id="secReq_${idx}" />
          <label class="form-check-label" for="secReq_${idx}"
                 style="font-size:10px;font-weight:700;color:#334;">REQUIRED</label>
        </div>
      </div>
      <div>
        <label style="font-size:10px;color:#556;font-weight:700;">NOTES <span style="font-weight:400;">(optional)</span></label>
        <input type="text" name="NewItems[${idx}].Notes" class="form-control form-control-sm"
               placeholder="e.g. any edition after 2020 ok" style="font-size:11px;" />
      </div>
    </div>`;

  document.getElementById('secItemsContainer').appendChild(div);
}

// ── Add Supply row ────────────────────────────────────────────
function secAddSupply() {
  const idx = secItemCount++;
  document.getElementById('secEmptyMsg').style.display = 'none';

  const div = document.createElement('div');
  div.id = `secItem_${idx}`;
  div.style.cssText = 'background:#fff;border:1px solid #dde;border-radius:4px;padding:12px;margin-bottom:10px;';
  div.innerHTML = `
    <input type="hidden" name="NewItems[${idx}].ItemType" value="Supply"/>

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
      <span style="background:#445566;color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:3px;letter-spacing:.4px;">
        <i class="bi bi-box-seam me-1"></i>NEW SUPPLY #${idx + 1}
      </span>
      <button type="button" onclick="secRemoveItem('secItem_${idx}')"
              style="background:none;border:1px solid #e55;color:#e55;border-radius:3px;padding:2px 8px;font-size:10px;cursor:pointer;">
        <i class="bi bi-trash"></i> REMOVE
      </button>
    </div>

    <div style="display:grid;grid-template-columns:2fr 60px 1fr 1fr;gap:8px;align-items:end;">
      <div>
        <label style="font-size:10px;color:#556;font-weight:700;">SUPPLY DESCRIPTION <span style="color:red;">*</span></label>
        <input type="text" name="NewItems[${idx}].SupplyDescription" class="form-control form-control-sm"
               placeholder="e.g. Scientific calculator TI-84" style="font-size:12px;" />
      </div>
      <div>
        <label style="font-size:10px;color:#556;font-weight:700;">QTY</label>
        <input type="number" name="NewItems[${idx}].Quantity" value="1" min="1"
               class="form-control form-control-sm" style="font-size:12px;" />
      </div>
      <div style="padding-bottom:4px;">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="NewItems[${idx}].IsRequired"
                 value="true" checked id="secReq_${idx}" />
          <label class="form-check-label" for="secReq_${idx}"
                 style="font-size:10px;font-weight:700;color:#334;">REQUIRED</label>
        </div>
      </div>
      <div>
        <label style="font-size:10px;color:#556;font-weight:700;">NOTES</label>
        <input type="text" name="NewItems[${idx}].Notes" class="form-control form-control-sm"
               placeholder="Optional" style="font-size:11px;" />
      </div>
    </div>`;

  document.getElementById('secItemsContainer').appendChild(div);
}

// ── ISBN lookup ───────────────────────────────────────────────
async function secLookupByIsbn(idx) {
  const raw  = (document.getElementById(`secIsbnInput_${idx}`)?.value || '').trim();
  const isbn = raw.replace(/[-\s]/g, '');
  if (!isbn) { secShowIsbnError(idx, 'Please enter an ISBN.'); return; }

  secClearConfirmation(idx);
  document.getElementById(`secIsbnSpinner_${idx}`).classList.remove('d-none');
  document.getElementById(`secIsbnError_${idx}`).classList.add('d-none');

  try {
    const res = await fetch(`/api/isbn-direct?isbn=${encodeURIComponent(isbn)}`);
    document.getElementById(`secIsbnSpinner_${idx}`).classList.add('d-none');

    if (res.status === 404) {
      secShowManualEntry(idx, isbn);
      return;
    }
    if (!res.ok) {
      secShowIsbnError(idx, 'Lookup failed. Please try again.');
      return;
    }
    const book = await res.json();
    secShowConfirmation(idx, book);
  } catch(e) {
    document.getElementById(`secIsbnSpinner_${idx}`).classList.add('d-none');
    secShowIsbnError(idx, 'Network error. Please check your connection.');
  }
}

function secShowIsbnError(idx, msg) {
  const el = document.getElementById(`secIsbnError_${idx}`);
  if (el) { el.textContent = msg; el.classList.remove('d-none'); }
}

// ── Manual entry (ISBN not in any catalog) ────────────────────
function secShowManualEntry(idx, isbn) {
  document.getElementById(`secManualPanel_${idx}`)?.remove();

  const bar = document.getElementById(`secIsbnBar_${idx}`);
  if (!bar) return;

  const panel = document.createElement('div');
  panel.id = `secManualPanel_${idx}`;
  panel.className = 'mt-2';
  panel.innerHTML = `
    <div style="border:1px solid #f59e0b;border-radius:4px;overflow:hidden;">
      <div style="background:#fef3c7;padding:8px 12px;font-size:10px;font-weight:700;color:#92400e;">
        <i class="bi bi-exclamation-triangle me-1"></i>
        ISBN <code>${secEscHtml(isbn)}</code> not found in online catalogs —
        <span style="font-weight:400;">enter details manually (they will be saved to the local catalog)</span>
      </div>
      <div style="padding:10px 12px;background:#fffdf5;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
          <div>
            <label style="font-size:10px;font-weight:700;color:#556;">TITLE <span style="color:red;">*</span></label>
            <input type="text" id="secM_title_${idx}" class="form-control form-control-sm"
                   placeholder="Book title" style="font-size:12px;" />
          </div>
          <div>
            <label style="font-size:10px;font-weight:700;color:#556;">AUTHOR(S)</label>
            <input type="text" id="secM_author_${idx}" class="form-control form-control-sm"
                   placeholder="Author name(s)" style="font-size:12px;" />
          </div>
          <div>
            <label style="font-size:10px;font-weight:700;color:#556;">PUBLISHER</label>
            <input type="text" id="secM_publisher_${idx}" class="form-control form-control-sm"
                   placeholder="Publisher" style="font-size:12px;" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
            <div>
              <label style="font-size:10px;font-weight:700;color:#556;">EDITION</label>
              <input type="text" id="secM_edition_${idx}" class="form-control form-control-sm"
                     placeholder="e.g. 3rd" style="font-size:12px;" />
            </div>
            <div>
              <label style="font-size:10px;font-weight:700;color:#556;">YEAR</label>
              <input type="number" id="secM_year_${idx}" class="form-control form-control-sm"
                     placeholder="2024" min="1900" max="2099" style="font-size:12px;" />
            </div>
          </div>
        </div>
      </div>
      <div style="padding:8px 12px;background:#fef9ec;display:flex;gap:6px;">
        <button type="button" onclick="secConfirmManualEntry(${idx}, '${isbn.replace(/'/g, "\\'")}')"
                style="background:#f59e0b;color:#1a1a1a;border:none;border-radius:3px;
                       padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;">
          <i class="bi bi-check-lg me-1"></i>USE THESE DETAILS
        </button>
        <button type="button" onclick="secCancelManualEntry(${idx})"
                style="background:none;border:1px solid #aaa;border-radius:3px;
                       padding:4px 10px;font-size:10px;cursor:pointer;">
          CANCEL
        </button>
      </div>
    </div>`;

  bar.appendChild(panel);
}

function secConfirmManualEntry(idx, isbn) {
  const title = (document.getElementById(`secM_title_${idx}`)?.value || '').trim();
  if (!title) { alert('Please enter a book title.'); return; }

  const book = {
    isbn,
    title,
    author:    document.getElementById(`secM_author_${idx}`)?.value    || '',
    publisher: document.getElementById(`secM_publisher_${idx}`)?.value || '',
    edition:   document.getElementById(`secM_edition_${idx}`)?.value   || '',
    year:      parseInt(document.getElementById(`secM_year_${idx}`)?.value || '') || null,
    fromLocalCache: false
  };

  secShowConfirmation(idx, book);
  document.getElementById(`secManualPanel_${idx}`)?.remove();
}

function secCancelManualEntry(idx) {
  document.getElementById(`secManualPanel_${idx}`)?.remove();
  const inp = document.getElementById(`secIsbnInput_${idx}`);
  if (inp) inp.value = '';
}

// ── Show/confirm/clear/reset confirmation panel ───────────────
function secShowConfirmation(idx, book) {
  const setTxt = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  setTxt(`secConfTitle_${idx}`,     book.title     || '(no title)');
  setTxt(`secConfAuthor_${idx}`,    book.author    || '—');
  setTxt(`secConfIsbn_${idx}`,      book.isbn      || '—');
  setTxt(`secConfPublisher_${idx}`, book.publisher || '—');
  setTxt(`secConfEdition_${idx}`,   book.edition   || '—');
  setTxt(`secConfYear_${idx}`,      book.year ? String(book.year) : '—');

  const cacheTag = document.getElementById(`secCacheTag_${idx}`);
  if (cacheTag) cacheTag.classList.toggle('d-none', !book.fromLocalCache);

  // ── License fee row (shown when VitalSource found a price) ─────────────
  const feeWrap = document.getElementById(`secConfLicenseFeeWrap_${idx}`);
  const feeTxt  = document.getElementById(`secConfLicenseFeeText_${idx}`);
  if (feeWrap && feeTxt) {
    const rawPrice = book.vitalSourcePrice ?? book.vitalsourcePrice ?? null;
    const days     = book.vitalSourcePriceDays ?? book.vitalsourcePriceDays ?? null;
    if (book.digitalOnVitalSource && rawPrice != null && Number(rawPrice) > 0) {
      const daysLabel = days ? ` (${days}-day rental)` : '';
      feeTxt.textContent = `$${Number(rawPrice).toFixed(2)}${daysLabel}`;
      feeWrap.classList.remove('d-none');
      feeWrap.style.display = 'flex';
    } else {
      feeWrap.classList.add('d-none');
      feeWrap.style.display = 'none';
    }
  }

  const panel = document.getElementById(`secConfirmPanel_${idx}`);
  if (panel) { panel._bookData = book; panel.classList.remove('d-none'); }
}

function secConfirmBook(idx) {
  const panel = document.getElementById(`secConfirmPanel_${idx}`);
  const book  = panel?._bookData;
  if (!book) return;

  const setVal = (id, v) => { const el = document.getElementById(id); if (el) el.value = v; };
  setVal(`secH_title_${idx}`,     book.title     || '');
  setVal(`secH_author_${idx}`,    book.author    || '');
  setVal(`secH_isbn_${idx}`,      book.isbn      || '');
  setVal(`secH_publisher_${idx}`, book.publisher || '');
  setVal(`secH_edition_${idx}`,   book.edition   || '');
  setVal(`secH_year_${idx}`,      book.year ? String(book.year) : '');

  const setTxt = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  setTxt(`secConfirmedTitle_${idx}`, book.title || '');
  setTxt(`secConfirmedIsbn_${idx}`,  book.isbn  || '');

  panel.classList.add('d-none');
  const bar = document.getElementById(`secIsbnBar_${idx}`);
  if (bar) bar.style.display = 'none';
  document.getElementById(`secBookFields_${idx}`)?.classList.remove('d-none');
}

function secClearConfirmation(idx) {
  const panel = document.getElementById(`secConfirmPanel_${idx}`);
  if (panel) { panel.classList.add('d-none'); panel._bookData = null; }
  const err = document.getElementById(`secIsbnError_${idx}`);
  if (err) err.classList.add('d-none');
}

function secResetBook(idx) {
  const bar = document.getElementById(`secIsbnBar_${idx}`);
  if (bar) bar.style.display = '';
  document.getElementById(`secBookFields_${idx}`)?.classList.add('d-none');
  secClearConfirmation(idx);
  ['secH_title_','secH_author_','secH_isbn_','secH_publisher_','secH_edition_','secH_year_']
    .forEach(p => { const el = document.getElementById(p + idx); if (el) el.value = ''; });
  const inp = document.getElementById(`secIsbnInput_${idx}`);
  if (inp) inp.value = '';
}

// ── Remove item row ───────────────────────────────────────────
function secRemoveItem(id) {
  document.getElementById(id)?.remove();
  if (document.getElementById('secItemsContainer').children.length === 0)
    document.getElementById('secEmptyMsg').style.display = '';
}

// ── Escape helper (local, safe to re-declare) ─────────────────
function secEscHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Reset the new-materials section whenever modal is closed ──
document.getElementById('addSectionModal')?.addEventListener('hidden.bs.modal', () => {
  document.getElementById('secItemsContainer').innerHTML = '';
  document.getElementById('secEmptyMsg').style.display = '';
  secItemCount = 0;
});

// ═══════════════════════════════════════════════════════════════
//  DIGITAL MATCH — instant checkmarks from server cache,
//                  async API fetch only for uncached ISBNs
// ═══════════════════════════════════════════════════════════════

// Pre-loaded from server (IMemoryCache) — instant, no network call.
// Keys are normalised ISBNs (digits only, no dashes).
const serverCache = @Html.Raw(ViewBag.AvailabilityCache ?? "{}");

const CHECKMARK_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
  viewBox="0 0 24 24" fill="none" stroke="#2e7d32" stroke-width="3"
  stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;">
  <polyline points="20 6 9 17 4 12"></polyline>
</svg>`;

function applyCheckmark(el) {
  const iconEl = el.querySelector('i');
  if (iconEl) {
    const span = document.createElement('span');
    span.innerHTML = CHECKMARK_SVG;
    iconEl.replaceWith(span);
  }
  el.style.color = '#2e7d32';
  el.style.fontWeight = '700';
}

function applyAvailData(el, data) {
  // ── DIGITAL MATCH (VitalSource hit = digital book 100%) ──────────────
  if (data.digitalVitalSource) {
    applyCheckmark(el);
  }

  // ── HAS IA PRICE ─────────────────────────────────────────────────────
  const priceVal  = data.vitalSourcePrice || data.printPrice || data.googlePrice;
  const hasPrice  = !!(priceVal || data.digitalVitalSource || data.digitalGoogle);
  const priceFlag = el.closest('.mat-ia-flags-row')?.querySelector('[data-isbn-price]');
  if (priceFlag && hasPrice) {
    applyCheckmark(priceFlag);
  }

  // ── LIST PRICE line below PUBLICATION DATE ────────────────────────────
  const itemId   = el.dataset.itemId;
  const priceDiv = itemId ? document.getElementById('mat-price-' + itemId) : null;
  if (priceDiv) {
    if (data.vitalSourcePrice) {
      priceDiv.textContent = 'LIST PRICE: $' + parseFloat(data.vitalSourcePrice).toFixed(2) + ' (120-day rental)';
      priceDiv.style.display = '';
    } else if (priceVal) {
      priceDiv.textContent = 'LIST PRICE: $' + parseFloat(priceVal).toFixed(2);
      priceDiv.style.display = '';
    }
  }
}

document.querySelectorAll('.mat-ia-flag[data-isbn]').forEach(async el => {
  const rawIsbn = el.dataset.isbn || '';
  // Normalise ISBN: strip dashes/spaces so it matches the cache key
  const isbn = rawIsbn.replace(/[-\s]/g, '');
  if (!isbn) return;

  // ── Fast path: serve from server-side cache (instant, no network) ────
  if (serverCache[isbn]) {
    applyAvailData(el, serverCache[isbn]);
    return; // done — no async fetch needed
  }

  // ── Slow path: ISBN not yet cached — fetch from API, then cache ─────
  try {
    const resp = await fetch('/api/check-availability?isbn=' + encodeURIComponent(isbn));
    if (!resp.ok) return;
    const data = await resp.json();
    // Store in local JS cache so navigating within the same page session is fast
    serverCache[isbn] = data;
    applyAvailData(el, data);
  } catch(e) { /* silent — availability check is best-effort */ }
});
</script>
}
