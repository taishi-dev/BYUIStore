<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] – BYUI University Store</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="verba-body">

@{
  var fullName  = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "";
  var role      = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
  var semester  = "SPRING 2026";
  var pageTitle = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? "COURSES";
  var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!-- ═══ Top Navigation Bar ═══ -->
<header class="verba-topbar">
  <a asp-controller="Dashboard" asp-action="Index" class="verba-brand" style="text-decoration:none;cursor:pointer;">
    <div class="brand-byuidaho">
      <span class="brand-byu">BYU</span>
      <span class="brand-idaho">IDAHO</span>
    </div>
    <div class="brand-divider-v"></div>
    <span class="brand-store-name">UNIVERSITY STORE</span>
  </a>

  @if (User.Identity?.IsAuthenticated == true)
  {
  <nav class="verba-topnav-links">
    <a class="topnav-link @(controller=="Courses" || controller=="Requests" ? "active" : "")"
       asp-controller="Courses" asp-action="Index">COURSES</a>
    <a class="topnav-link @(controller=="Availability" ? "active" : "")"
       asp-controller="Availability" asp-action="Index">ITEMS</a>
    <a class="topnav-link" href="#">DEPARTMENTS</a>
    <a class="topnav-link" href="#">USERS</a>
  </nav>
  <div class="verba-topbar-right">
    <a class="topbar-icon-btn" href="#" title="Export"><i class="bi bi-download"></i></a>
    <a class="topbar-icon-btn" href="#" title="Settings"><i class="bi bi-gear"></i></a>
    <a class="topbar-icon-btn" href="#" title="Help">
      <span class="btn-get-help">GET HELP</span>
    </a>
    <span class="topbar-user ms-2">
      <i class="bi bi-person-circle me-1"></i>@fullName
    </span>
    <a class="topbar-logout ms-2" asp-controller="Account" asp-action="Logout" title="Logout">
      <i class="bi bi-box-arrow-right"></i>
    </a>
  </div>
  }
</header>

<!-- ═══ Sub-Header Banner ═══ -->
@if (User.Identity?.IsAuthenticated == true)
{
<div class="verba-subheader">
  <div class="subheader-left">
    <div class="subheader-semester">@semester</div>
    <div class="subheader-title">@pageTitle.ToUpper()</div>
  </div>
  <div class="subheader-right">
    @await RenderSectionAsync("SubHeaderActions", required: false)
    @if (!IsSectionDefined("SubHeaderActions"))
    {
      <div class="term-selector-group">
        <select class="form-select form-select-sm term-select">
          <option>SPRING 2026</option>
          <option>WINTER 2026</option>
          <option>FALL 2025</option>
        </select>
        <button class="btn btn-sm btn-outline-light ms-2">
          <i class="bi bi-gear-fill me-1"></i>TERM SETTINGS
        </button>
      </div>
    }
  </div>
</div>
}

<!-- ═══ Flash Messages ═══ -->
@if (TempData["Success"] is string success)
{
<div class="alert alert-success alert-dismissible fade show m-3 mb-0" role="alert">
  <i class="bi bi-check-circle-fill me-2"></i>@success
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["Warning"] is string warning)
{
<div class="alert alert-warning alert-dismissible fade show m-3 mb-0" role="alert">
  <i class="bi bi-exclamation-triangle-fill me-2"></i>@warning
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["Error"] is string error)
{
<div class="alert alert-danger alert-dismissible fade show m-3 mb-0" role="alert">
  <i class="bi bi-x-circle-fill me-2"></i>@error
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}

<!-- ═══ Main Content ═══ -->
@RenderBody()

<!-- ═══ Footer ═══ -->
<footer class="verba-footer">
  <span>© 2026 VERBA | VITALSOURCE</span>
  <a href="#">PRIVACY POLICY</a>
  <a href="#">COOKIE POLICY</a>
  <a href="#">ACCESSIBILITY POLICY</a>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/isbn-search.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
