@using BYUIVerbaCollect.Models
@using BYUIVerbaCollect.Services
@model BookAvailabilityItem
@{
    ViewData["Title"] = "Item Details";
    var avail      = ViewBag.Avail       as BookAvailabilityItem ?? Model;
    var adoptions  = ViewBag.Adoptions   as List<CourseRequest>  ?? new();
    var allBooks   = ViewBag.AllBooks    as List<BookAvailabilityItem> ?? new();
    var termAvg    = (int)(ViewBag.TermAvg ?? 50);
    var semester   = (string)(ViewBag.LatestSemester ?? "");

    // Histogram bins
    var booksWithScore = allBooks.Where(b => b.AffordabilityScore.HasValue).ToList();
    var bins = new int[10];
    foreach (var b in booksWithScore)
        bins[b.AffordabilityScore!.Value / 10]++;
    int maxBin = bins.Max() > 0 ? bins.Max() : 1;
    string[] labels = { "0-9","10-19","20-29","30-39","40-49","50-59","60-69","70-79","80-89","90-99" };

    bool hasDigital = avail.DigitalAvailableOnVitalSource || avail.EbookAvailableOnGoogle;
    bool hasPrice   = avail.PrintRetailPrice.HasValue || avail.PrintListPrice.HasValue || avail.EbookPrice.HasValue;
    decimal? listPrice = avail.PrintRetailPrice ?? avail.PrintListPrice ?? avail.EbookPrice;
    int totalEnrollment = adoptions.Sum(r =>
    {
        // count unique students: use Enrollments if available, else 0
        return 0; // enrollment data via DB not pulled here — shown as 0
    });
    int adoptionCount = adoptions.Count;
}

<!-- ══ Page header ══ -->
<div class="page-header">
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <h2><i class="bi bi-journal-text me-2"></i>Items</h2>
      <p class="mb-0 opacity-75">
        <a class="text-white" asp-controller="Availability" asp-action="Index">← Back to Book Availability Report</a>
      </p>
    </div>
    <a asp-controller="Availability" asp-action="Index"
       class="btn btn-sm btn-outline-light mt-1">
      <i class="bi bi-arrow-left me-1"></i>All Items
    </a>
  </div>
</div>

<!-- ══ Affordability Histogram ══ -->
<div style="background:#2d2d2d;color:#fff;padding:24px 28px 18px;margin-bottom:20px;border-radius:4px;position:relative;">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
    <div style="font-size:11px;font-weight:700;letter-spacing:.8px;color:#ccc;text-transform:uppercase;">
      @semester<br>
      <span style="font-size:16px;color:#fff;">ITEMS</span>
    </div>
    <div style="text-align:center;position:absolute;left:50%;transform:translateX(-50%);top:18px;">
      <span style="font-size:44px;font-weight:900;line-height:1;">@termAvg</span>
      <span style="font-size:10px;font-weight:700;letter-spacing:.6px;color:#aaa;display:block;margin-top:-2px;">TERM AVERAGE</span>
    </div>
    <div></div>
  </div>
  <div style="display:flex;justify-content:space-between;font-size:10px;color:#aaa;font-weight:700;letter-spacing:.6px;margin-bottom:4px;">
    <span>◄ WORSE</span><span>BETTER ►</span>
  </div>
  <div style="display:flex;gap:0;height:120px;align-items:flex-end;position:relative;padding-left:28px;">
    <div style="position:absolute;left:0;top:50%;transform:translateY(-50%) rotate(-90deg);font-size:7px;color:#aaa;letter-spacing:.4px;font-weight:700;white-space:nowrap;transform-origin:center;">
      COUNT OF TITLES IN RANGE
    </div>
    @for (int i = 0; i < 10; i++)
    {
      double pct = (double)bins[i] / maxBin * 100.0;
      bool isAvg = (termAvg / 10) == i;
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;">
        @if (isAvg)
        {
          <div style="position:absolute;top:0;bottom:0;left:50%;border-left:2px dotted #fff;transform:translateX(-50%);z-index:2;"></div>
        }
        <div style="width:80%;background:@(pct>0?"#2196f3":"#444");height:@(pct>0?pct:2)%;
             border-radius:2px 2px 0 0;min-height:4px;margin-top:auto;position:relative;z-index:1;"></div>
      </div>
    }
  </div>
  <div style="display:flex;gap:0;padding-left:28px;margin-top:3px;">
    @foreach (var lbl in labels)
    { <div style="flex:1;text-align:center;font-size:8px;color:#aaa;font-weight:600;">@lbl</div> }
  </div>
  <div style="text-align:center;font-size:9px;color:#aaa;font-weight:700;margin-top:6px;text-transform:uppercase;">
    Range of Affordability Score Points
  </div>
</div>

<!-- ══ Content Layout: sidebar + main ══ -->
<div style="display:flex;gap:16px;align-items:flex-start;">

  <!-- ── LEFT SIDEBAR ── -->
  <div style="width:220px;flex-shrink:0;">
    <div style="background:#fff;border:1px solid #dde;border-radius:4px;padding:12px;">
      <!-- ISBN search -->
      <form asp-action="Item" method="get" style="display:flex;gap:4px;margin-bottom:14px;">
        <input name="isbn" type="text" value="@avail.Isbn"
               style="flex:1;font-size:12px;border:1px solid #ccd;border-radius:3px;padding:4px 8px;"
               placeholder="Search ISBN…" />
        <button type="submit" style="background:#444;color:#fff;border:none;border-radius:3px;padding:4px 8px;">
          <i class="bi bi-search" style="font-size:11px;"></i>
        </button>
      </form>

      <!-- Filter: Department -->
      <div style="font-size:9px;font-weight:700;color:#889;letter-spacing:.6px;margin-bottom:4px;text-transform:uppercase;">FILTER BY DEPARTMENT</div>
      <select class="form-select form-select-sm mb-3" style="font-size:11px;">
        <option>ALL DEPARTMENTS</option>
      </select>

      <!-- Filter: IA Status -->
      <div style="font-size:9px;font-weight:700;color:#889;letter-spacing:.6px;margin-bottom:4px;text-transform:uppercase;">FILTER BY IA STATUS</div>
      <select class="form-select form-select-sm mb-3" style="font-size:11px;">
        <option>ALL IA STATUSES</option>
      </select>

      <!-- Filter: IA Price -->
      <div style="font-size:9px;font-weight:700;color:#889;letter-spacing:.6px;margin-bottom:6px;text-transform:uppercase;">INCLUSIVE ACCESS PRICE FILTERS</div>
      <div class="form-check mb-1">
        <input class="form-check-input" type="checkbox" @(hasPrice ? "checked" : "")>
        <label class="form-check-label" style="font-size:11px;">Has IA Price Available</label>
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" @(!hasPrice ? "checked" : "")>
        <label class="form-check-label" style="font-size:11px;">No IA Price Available</label>
      </div>

      <!-- Filter: Digital Match -->
      <div style="font-size:9px;font-weight:700;color:#889;letter-spacing:.6px;margin-bottom:6px;text-transform:uppercase;">DIGITAL MATCH FILTERS</div>
      <div class="form-check mb-1">
        <input class="form-check-input" type="checkbox" @(hasDigital ? "checked" : "")>
        <label class="form-check-label" style="font-size:11px;">Has Digital Match</label>
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" @(!hasDigital ? "checked" : "")>
        <label class="form-check-label" style="font-size:11px;">No Digital Match</label>
      </div>

      <!-- Filter: Adoption Type -->
      <div style="font-size:9px;font-weight:700;color:#889;letter-spacing:.6px;margin-bottom:6px;text-transform:uppercase;">ADOPTION TYPE</div>
      <div class="form-check mb-1">
        <input class="form-check-input" type="checkbox" checked>
        <label class="form-check-label" style="font-size:11px;">Is a Book</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox">
        <label class="form-check-label" style="font-size:11px;">Is a Supply</label>
      </div>
    </div>
  </div>

  <!-- ── MAIN CONTENT ── -->
  <div style="flex:1;min-width:0;">

    <!-- Viewing count bar -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <span style="font-size:12px;font-weight:700;color:#334;letter-spacing:.4px;text-transform:uppercase;">
        VIEWING 1 ITEM
      </span>
      <div style="display:flex;gap:8px;">
        <button style="background:#2196f3;color:#fff;border:none;border-radius:3px;padding:6px 14px;font-size:11px;font-weight:700;">
          <i class="bi bi-envelope-fill me-1"></i>MESSAGE FILTERED USERS
        </button>
        <button style="background:#2196f3;color:#fff;border:none;border-radius:3px;padding:6px 14px;font-size:11px;font-weight:700;">
          <i class="bi bi-download me-1"></i>ITEMS EXPORT
        </button>
      </div>
    </div>

    <!-- Book card (dark) -->
    <div style="background:#2d2d2d;color:#fff;border-radius:4px;padding:20px 24px;margin-bottom:0;">
      <div style="display:flex;gap:16px;align-items:flex-start;">

        <!-- Cover -->
        <div style="width:60px;height:80px;background:#555;border-radius:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;overflow:hidden;">
          @if (!string.IsNullOrEmpty(avail.CoverThumbnailUrl))
          {
            <img src="@avail.CoverThumbnailUrl" alt="cover" style="width:100%;height:100%;object-fit:cover;" />
          }
          else
          {
            <i class="bi bi-book" style="color:#aaa;font-size:20px;"></i>
          }
        </div>

        <!-- Title + metadata + badges -->
        <div style="flex:1;min-width:0;">
          <div style="font-size:15px;font-weight:800;letter-spacing:.3px;text-transform:uppercase;margin-bottom:2px;">
            @(avail.Title?.ToUpper() ?? "UNKNOWN TITLE")
          </div>
          @if (!string.IsNullOrEmpty(avail.Author))
          {
            <div style="font-size:11px;color:#bbb;margin-bottom:2px;">@avail.Author.ToUpper()</div>
          }
          <div style="font-size:11px;color:#aaa;margin-bottom:1px;">VBID: @avail.Isbn</div>
          <div style="font-size:11px;color:#aaa;margin-bottom:8px;">ISBN: @avail.Isbn</div>

          <!-- Badges -->
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            @if (hasDigital)
            {
              <span style="background:#2e7d32;color:#fff;font-size:11px;font-weight:700;
                           padding:4px 12px;border-radius:16px;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-check-circle-fill"></i> HAS DIGITAL MATCH
              </span>
            }
            else
            {
              <span style="background:#555;color:#aaa;font-size:11px;font-weight:700;
                           padding:4px 12px;border-radius:16px;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-question-circle"></i> NO DIGITAL MATCH
              </span>
            }
            @if (hasPrice)
            {
              <span style="background:#2e7d32;color:#fff;font-size:11px;font-weight:700;
                           padding:4px 12px;border-radius:16px;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-currency-dollar"></i> HAS IA PRICE
                @if (listPrice.HasValue)
                { <span style="opacity:.85;">— $@listPrice.Value.ToString("F2")</span> }
              </span>
            }
            else
            {
              <span style="background:#555;color:#aaa;font-size:11px;font-weight:700;
                           padding:4px 12px;border-radius:16px;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-currency-dollar"></i> NO IA PRICE
              </span>
            }
          </div>
        </div>

        <!-- Right buttons -->
        <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0;">
          <button style="background:transparent;border:1px solid #aaa;color:#fff;
                         border-radius:3px;padding:6px 14px;font-size:11px;font-weight:700;">
            <i class="bi bi-envelope me-1"></i> MESSAGE USERS
          </button>
          <a href="@avail.VitalSourceUrl" target="_blank"
             style="background:transparent;border:1px solid #aaa;color:#fff;
                    border-radius:3px;padding:6px 14px;font-size:11px;font-weight:700;text-decoration:none;text-align:center;">
            <i class="bi bi-tablet me-1"></i> VIEW ON VITALSOURCE ↗
          </a>
          <a href="@avail.AmazonUrl" target="_blank"
             style="background:transparent;border:1px solid #aaa;color:#fff;
                    border-radius:3px;padding:6px 14px;font-size:11px;font-weight:700;text-decoration:none;text-align:center;">
            <i class="bi bi-bag me-1"></i> VIEW ON AMAZON ↗
          </a>
        </div>
      </div>

      <!-- Adopted in X courses bar -->
      <div style="border-top:1px solid #444;margin-top:16px;padding-top:12px;
                  display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:11px;font-weight:700;color:#ccc;letter-spacing:.5px;text-transform:uppercase;">
          ADOPTED IN @adoptionCount COURSE@(adoptionCount != 1 ? "S" : "")
        </span>
        <div style="display:flex;gap:24px;text-align:center;">
          <div>
            <div style="font-size:22px;font-weight:800;">@adoptions.Sum(r => r.Items.Count > 0 ? 1 : 0)</div>
            <div style="font-size:9px;color:#aaa;font-weight:700;letter-spacing:.4px;">SECTIONS</div>
          </div>
          <div>
            <div style="font-size:22px;font-weight:800;">@(avail.AffordabilityScore?.ToString() ?? "—")</div>
            <div style="font-size:9px;color:#aaa;font-weight:700;letter-spacing:.4px;">AFFORDABILITY</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Adoption rows (white cards) -->
    @foreach (var req in adoptions)
    {
      var reqItem = req.Items.FirstOrDefault(i => i.Isbn == avail.Isbn);
      <div style="background:#fff;border:1px solid #dde;border-radius:4px;margin-top:8px;padding:14px 18px;
                  display:flex;gap:12px;align-items:flex-start;">

        <!-- Dots + enrollment -->
        <div style="text-align:center;flex-shrink:0;min-width:52px;">
          <div style="color:#3a8a3a;font-size:14px;letter-spacing:2px;">● ● ●</div>
          <div style="font-size:18px;font-weight:800;color:#334;">0</div>
          <div style="font-size:9px;color:#889;font-weight:700;letter-spacing:.4px;">STUDENTS</div>
        </div>

        <!-- Course info -->
        <div style="flex:1;min-width:0;">
          <div style="font-size:14px;font-weight:800;color:#334;margin-bottom:2px;">@req.CourseNumber</div>
          @if (reqItem is not null)
          {
            <div style="font-size:11px;color:#556;margin-bottom:1px;">ADOPTED ISBN: @reqItem.Isbn</div>
          }
          <div style="font-size:11px;color:#778;">
            @req.Submitter?.FullName
            @if (!string.IsNullOrEmpty(req.Section))
            { <span style="margin-left:4px;">(@req.Section)</span> }
          </div>
          <div style="font-size:10px;color:#aab;margin-top:2px;">@req.Semester</div>
        </div>

        <!-- Action buttons -->
        <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;flex-shrink:0;">
          <span style="font-size:10px;padding:3px 10px;border-radius:3px;font-weight:700;
            background:@(req.Status==RequestStatus.Approved?"#d4edda":req.Status==RequestStatus.Verified?"#cce5ff":"#fff3cd");
            color:@(req.Status==RequestStatus.Approved?"#155724":req.Status==RequestStatus.Verified?"#004085":"#856404");">
            @req.Status
          </span>
          <button style="background:#e8eaed;border:none;border-radius:3px;padding:5px 12px;font-size:10px;font-weight:700;">
            <i class="bi bi-info-circle me-1"></i> NO IA INTEREST
          </button>
          <a asp-controller="Requests" asp-action="Details" asp-route-id="@req.Id"
             style="background:#334;color:#fff;border:none;border-radius:3px;padding:5px 12px;
                    font-size:10px;font-weight:700;text-decoration:none;display:inline-block;">
            <i class="bi bi-box-arrow-up-right me-1"></i> GO TO ADOPTION
          </a>
        </div>
      </div>
    }

    @if (!adoptions.Any())
    {
      <div style="background:#fff;border:1px solid #dde;border-radius:4px;margin-top:8px;padding:24px;text-align:center;color:#889;">
        <i class="bi bi-info-circle me-2"></i>This ISBN has not been adopted in any course request yet.
      </div>
    }

  </div><!-- /main -->
</div><!-- /layout -->
